rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // --- Validation Helpers ---
    
    function isValidUser(data) {
      return data.email is string && data.email.size() <= 200
          && data.onboardingStatus in ['in-progress', 'completed']
          && data.currentOnboardingStep is int
          && data.currentOnboardingStep >= 1 && data.currentOnboardingStep <= 6;
    }

    function isValidBusiness(data) {
      return data.ownerId == request.auth.uid
          && (data.name == null || (data.name is string && data.name.size() <= 100))
          && (data.currency == null || (data.currency is string && data.currency.size() <= 10))
          && (data.paymentConfig == null || (data.paymentConfig.type in ['custom', 'platform']));
    }

    function isValidInvoice(data) {
      return data.businessId is string 
          && data.total is number 
          && data.status in ['draft', 'sent', 'paid'];
    }

    // --- Collection Routes ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
          && isValidUser(incoming())
          && incoming().onboardingStatus == 'in-progress'
          && incoming().currentOnboardingStep == 1
          && incoming().isVerified == false;
      allow update: if isOwner(userId)
          && isValidUser(incoming())
          && (
            // Action: Increment step
            (incoming().diff(existing()).affectedKeys().hasOnly(['currentOnboardingStep', 'updatedAt', 'onboardingStatus']))
            || 
            // Action: Verify Email (Usually via server, but allowing restricted update here if client-side logic sends token)
            (incoming().diff(existing()).affectedKeys().hasOnly(['isVerified', 'updatedAt']))
          );
      allow delete: if false;
    }

    match /businesses/{businessId} {
      allow get: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() 
          && isValidBusiness(incoming())
          && isValidId(businessId);
      allow update: if isSignedIn() 
          && existing().ownerId == request.auth.uid
          && isValidBusiness(incoming())
          && incoming().ownerId == existing().ownerId; // Immortal field
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }

    match /businesses/{businessId}/invoices/{invoiceId} {
      allow read: if isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
      allow write: if isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid
          && isValidInvoice(incoming());
    }
  }
}
