rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- User Rules ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && request.resource.data.keys().hasAll(['email', 'createdAt'])
        && request.resource.data.email == request.auth.token.email;
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'onboarded', 'activeWorkspace']);
    }

    // --- Workspace Rules ---
    match /workspaces/{workspaceId} {
      function isWorkspaceOwner(data) {
        return data.ownerId == request.auth.uid;
      }

      allow get: if isWorkspaceOwner(resource.data);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.keys().hasAll(['name', 'ownerId', 'plan', 'createdAt'])
        && request.resource.data.plan == 'free'; // Default to free on create
        
      allow update: if isWorkspaceOwner(resource.data)
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'name', 'logoUrl', 'currency', 'address', 'contactEmail', 
            'taxId', 'paystackPublicKey', 'paystackSecretKey'
           ]);
    }

    // --- Invoice Rules ---
    match /workspaces/{workspaceId}/invoices/{invoiceId} {
      function canAccessWorkspace(wId) {
        return get(/databases/$(database)/documents/workspaces/$(wId)).data.ownerId == request.auth.uid;
      }

      allow read: if isSignedIn() && canAccessWorkspace(workspaceId);
      
      allow create: if isSignedIn() 
        && canAccessWorkspace(workspaceId)
        && request.resource.data.workspaceId == workspaceId
        && request.resource.data.keys().hasAll(['workspaceId', 'clientId', 'invoiceNumber', 'status', 'total', 'createdAt']);
        
      allow update: if isSignedIn()
        && canAccessWorkspace(workspaceId)
        && request.resource.data.workspaceId == resource.data.workspaceId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'clientId', 'invoiceNumber', 'status', 'issueDate', 'dueDate', 
            'items', 'subtotal', 'tax', 'discount', 'total', 'notes', 'templateId', 'updatedAt'
           ]);

      allow delete: if isSignedIn() && canAccessWorkspace(workspaceId);
    }

    // --- Client Rules ---
    match /workspaces/{workspaceId}/clients/{clientId} {
      function canAccessWorkspace(wId) {
        return get(/databases/$(database)/documents/workspaces/$(wId)).data.ownerId == request.auth.uid;
      }

      allow read: if isSignedIn() && canAccessWorkspace(workspaceId);
      
      allow create: if isSignedIn()
        && canAccessWorkspace(workspaceId)
        && request.resource.data.workspaceId == workspaceId;
        
      allow update: if isSignedIn()
        && canAccessWorkspace(workspaceId)
        && request.resource.data.workspaceId == resource.data.workspaceId;

      allow delete: if isSignedIn() && canAccessWorkspace(workspaceId);
    }
  }
}
