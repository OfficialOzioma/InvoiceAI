<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/output.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="bg-[#F8FAFC] text-[#1E293B] antialiased">
    <div class="flex">
        <%- include('partials/sidebar') %>
        <main class="flex-1 ml-64 p-10 min-h-screen">
            <!-- Header inside Dashboard -->
            <header class="flex items-center justify-between mb-10">
                <div class="relative w-96">
                    <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 text-muted w-4 h-4"></i>
                    <input type="text" placeholder="Search invoices, clients..." class="w-full bg-white border border-border rounded-lg pl-10 pr-4 py-2 text-sm outline-none focus:border-primary transition-all">
                </div>
                <div class="flex items-center gap-4">
                    <button class="bg-primary text-white px-5 py-2 rounded-md text-xs font-bold flex items-center gap-2 hover:bg-secondary transition-all">
                        <i data-lucide="plus" class="w-4 h-4"></i> AI Draft
                    </button>
                    <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center text-primary font-bold text-xs">
                        JD
                    </div>
                </div>
            </header>
            
            <%- body %>
        </main>
    </div>
    <script>
      lucide.createIcons();
    </script>
</body>
</html>
