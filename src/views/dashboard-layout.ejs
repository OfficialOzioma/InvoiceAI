<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/output.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head>
<body class="bg-[#F8FAFC] text-[#1E293B] antialiased pb-20 md:pb-0">
    <div class="flex">
        <!-- Desktop Sidebar (Hidden on Mobile) -->
        <aside class="hidden md:flex w-64 border-r border-border bg-white h-screen fixed left-0 top-0 flex-col z-40">
            <div class="p-6">
                <!-- Business Switcher / Logo -->
                <div class="flex items-center gap-3 mb-8">
                    <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center text-white font-bold text-xs shadow-sm shadow-blue-500/20">
                        <i data-lucide="briefcase" class="w-4 h-4"></i>
                    </div>
                    <div>
                        <div class="text-sm font-extrabold tracking-tight text-secondary">Acme Corp</div>
                        <div class="text-[9px] font-bold text-muted uppercase tracking-widest">Free Plan</div>
                    </div>
                </div>
                
                <nav class="space-y-1">
                    <a href="/dashboard" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-bold transition-all bg-blue-50 text-primary">
                        <i data-lucide="layout-grid" class="w-4 h-4"></i> Overview
                    </a>
                    <a href="/invoices" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-bold transition-all text-slate-500 hover:bg-slate-50 hover:text-secondary group">
                        <i data-lucide="file-text" class="w-4 h-4 text-slate-400 group-hover:text-secondary transition-colors"></i> Invoices
                    </a>
                    <a href="/clients" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-bold transition-all text-slate-500 hover:bg-slate-50 hover:text-secondary group">
                        <i data-lucide="users" class="w-4 h-4 text-slate-400 group-hover:text-secondary transition-colors"></i> Clients
                    </a>
                    <a href="/payments" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-bold transition-all text-slate-500 hover:bg-slate-50 hover:text-secondary group">
                        <i data-lucide="credit-card" class="w-4 h-4 text-slate-400 group-hover:text-secondary transition-colors"></i> Payments
                    </a>
                    <div class="pt-4 pb-2">
                        <div class="text-[10px] font-bold uppercase tracking-widest text-slate-400 px-3">Configuration</div>
                    </div>
                    <a href="/templates" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-bold transition-all text-slate-500 hover:bg-slate-50 hover:text-secondary group">
                        <i data-lucide="layout-template" class="w-4 h-4 text-slate-400 group-hover:text-secondary transition-colors"></i> Templates
                    </a>
                    <a href="/settings" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-bold transition-all text-slate-500 hover:bg-slate-50 hover:text-secondary group">
                        <i data-lucide="settings" class="w-4 h-4 text-slate-400 group-hover:text-secondary transition-colors"></i> Settings
                    </a>
                </nav>
            </div>

            <div class="mt-auto p-6 border-t border-slate-100">
                <a href="/profile" class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-primary font-bold text-xs ring-2 ring-white">
                        JD
                    </div>
                    <div class="flex-1 overflow-hidden">
                        <div class="text-xs font-bold text-secondary truncate">Jane Doe</div>
                        <div class="text-[10px] text-slate-500 truncate"><%= locals.user ? locals.user.email : 'jane@acme.com' %></div>
                    </div>
                </a>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="flex-1 md:ml-64 min-h-screen">
            <!-- Mobile Top Bar (Hamburger for Secondary Links) -->
            <div class="md:hidden flex items-center justify-between p-4 bg-white border-b border-border sticky top-0 z-30">
                <div class="flex items-center gap-2">
                    <div class="w-6 h-6 bg-primary rounded uppercase flex items-center justify-center text-white font-bold text-[10px]">
                        A
                    </div>
                    <div class="text-sm font-bold text-secondary tracking-tight">Acme Corp</div>
                </div>
                <div class="flex items-center gap-3">
                    <a href="/invoices/new" class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center shadow shadow-blue-500/20">
                        <i data-lucide="plus" class="w-4 h-4"></i>
                    </a>
                    <button id="mobileMenuBtn" class="w-8 h-8 rounded text-slate-500 flex items-center justify-center bg-slate-50 border border-slate-200">
                        <i data-lucide="menu" class="w-4 h-4"></i>
                    </button>
                </div>
            </div>

            <!-- Desktop Top Bar -->
            <header class="hidden md:flex items-center justify-between px-8 h-20 bg-white/50 backdrop-blur-sm border-b border-border sticky top-0 z-30">
                <div class="flex items-center gap-4">
                    <h2 class="text-lg font-black tracking-tight text-secondary">Dashboard</h2>
                </div>
                <div class="flex items-center gap-4">
                    <button class="w-10 h-10 rounded-full flex items-center justify-center text-slate-400 hover:text-secondary hover:bg-slate-100 transition-all relative">
                        <i data-lucide="bell" class="w-5 h-5"></i>
                        <span class="absolute top-2.5 right-2.5 w-2 h-2 bg-red-500 rounded-full ring-2 ring-white"></span>
                    </button>
                    <a href="/invoices/new" class="bg-primary hover:bg-secondary text-white px-5 py-2.5 rounded-xl text-xs font-bold flex items-center gap-2 transition-all shadow-lg shadow-blue-500/20">
                        <i data-lucide="plus" class="w-4 h-4"></i> Create Invoice
                    </a>
                </div>
            </header>
            
            <div class="p-6 lg:p-8 max-w-6xl mx-auto">
                <%- body %>
            </div>
        </main>

        <!-- Mobile Bottom Navigation -->
        <nav class="md:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-border flex justify-around items-center h-16 px-2 z-40 pb-safe shadow-[0_-4px_24px_rgba(0,0,0,0.04)]">
            <a href="/dashboard" class="flex flex-col items-center justify-center w-14 h-full <%= title.includes('Dashboard') ? 'text-primary' : 'text-slate-400 hover:text-slate-600' %> transition-colors">
                <i data-lucide="layout-grid" class="w-5 h-5 mb-1"></i>
                <span class="text-[9px] font-bold">Overview</span>
            </a>
            <a href="/invoices" class="flex flex-col items-center justify-center w-14 h-full <%= title.includes('Invoice') ? 'text-primary' : 'text-slate-400 hover:text-slate-600' %> transition-colors">
                <i data-lucide="file-text" class="w-5 h-5 mb-1"></i>
                <span class="text-[9px] font-bold">Invoices</span>
            </a>
            <a href="/clients" class="flex flex-col items-center justify-center w-14 h-full <%= title.includes('Client') ? 'text-primary' : 'text-slate-400 hover:text-slate-600' %> transition-colors">
                <i data-lucide="users" class="w-5 h-5 mb-1"></i>
                <span class="text-[9px] font-bold">Clients</span>
            </a>
            <a href="/payments" class="flex flex-col items-center justify-center w-14 h-full <%= title.includes('Payment') ? 'text-primary' : 'text-slate-400 hover:text-slate-600' %> transition-colors">
                <i data-lucide="credit-card" class="w-5 h-5 mb-1"></i>
                <span class="text-[9px] font-bold">Payments</span>
            </a>
            <a href="/profile" class="flex flex-col items-center justify-center w-14 h-full <%= title.includes('Profile') ? 'text-primary' : 'text-slate-400 hover:text-slate-600' %> transition-colors">
                <div class="w-6 h-6 rounded-full <%= title.includes('Profile') ? 'bg-blue-100 text-primary' : 'bg-slate-100 text-slate-500' %> flex items-center justify-center font-bold text-[9px] ring-2 ring-white mb-1">
                    JD
                </div>
                <span class="text-[9px] font-bold">Profile</span>
            </a>
        </nav>

        <!-- Mobile Drawer Menu (Initially Hidden) -->
        <div id="mobileDrawer" class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-50 hidden opacity-0 transition-opacity">
            <div id="mobileDrawerContent" class="absolute top-0 right-0 w-64 h-full bg-white shadow-2xl transform translate-x-full transition-transform duration-300 ease-out flex flex-col">
                <div class="p-4 flex items-center justify-between border-b border-border">
                    <span class="text-sm font-black text-secondary tracking-tight">Menu</span>
                    <button id="closeDrawerBtn" class="w-8 h-8 flex items-center justify-center text-slate-500 hover:text-secondary rounded-lg bg-slate-50">
                        <i data-lucide="x" class="w-4 h-4"></i>
                    </button>
                </div>
                <div class="p-4 flex-1 overflow-y-auto space-y-4">
                    <div class="space-y-1">
                        <div class="text-[10px] font-bold uppercase tracking-widest text-slate-400 px-3 mb-2">Configuration</div>
                        <a href="/templates" class="flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-bold transition-all text-slate-600 hover:bg-slate-50">
                            <div class="w-8 h-8 rounded-lg bg-slate-100 flex items-center justify-center"><i data-lucide="layout-template" class="w-4 h-4 text-slate-500"></i></div>
                            Templates
                        </a>
                        <a href="/settings" class="flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-bold transition-all text-slate-600 hover:bg-slate-50">
                            <div class="w-8 h-8 rounded-lg bg-slate-100 flex items-center justify-center"><i data-lucide="settings" class="w-4 h-4 text-slate-500"></i></div>
                            Settings
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script>
      lucide.createIcons();

      // Mobile Drawer Logic
      const menuBtn = document.getElementById('mobileMenuBtn');
      const closeBtn = document.getElementById('closeDrawerBtn');
      const drawer = document.getElementById('mobileDrawer');
      const drawerContent = document.getElementById('mobileDrawerContent');

      if (menuBtn && closeBtn && drawer && drawerContent) {
          const openDrawer = () => {
              drawer.classList.remove('hidden');
              // small delay to allow display:block to apply before animating opacity
              setTimeout(() => {
                  drawer.classList.remove('opacity-0');
                  drawerContent.classList.remove('translate-x-full');
              }, 10);
          };

          const closeDrawer = () => {
              drawer.classList.add('opacity-0');
              drawerContent.classList.add('translate-x-full');
              setTimeout(() => {
                  drawer.classList.add('hidden');
              }, 300); // match transition duration
          };

          menuBtn.addEventListener('click', openDrawer);
          closeBtn.addEventListener('click', closeDrawer);
          drawer.addEventListener('click', (e) => {
              if (e.target === drawer) closeDrawer();
          });
      }
    </script>
</body>
</html>
