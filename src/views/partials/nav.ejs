<header x-data="{ mobileMenuOpen: false }" class="h-20 w-full bg-white/80 backdrop-blur-md border-b border-slate-100 fixed top-0 z-[100]">
    <div class="max-w-7xl mx-auto h-full px-6 flex items-center justify-between">
        <!-- Logo -->
        <div class="flex items-center shrink-0">
            <a href="/" class="text-2xl font-black tracking-tighter text-secondary flex items-center gap-1">
                Invoice<span class="text-primary italic">AI</span>
            </a>
        </div>
        
        <!-- Centered Desktop Navigation -->
        <nav class="hidden lg:flex items-center justify-center flex-1 gap-8 text-[13px] font-bold uppercase tracking-widest text-slate-400">
            <a href="/#features" class="hover:text-primary transition-colors">Features</a>
            <a href="/#templates" class="hover:text-primary transition-colors">Templates</a>
            <a href="/#pricing" class="hover:text-primary transition-colors">Pricing</a>
            <a href="/#about" class="hover:text-primary transition-colors">About</a>
            <a href="/#contact" class="hover:text-primary transition-colors">Contact</a>
        </nav>
        
        <!-- Action Buttons & Mobile Toggle -->
        <div class="flex items-center gap-4 shrink-0">
            <a href="/login" class="hidden sm:block text-[13px] font-bold uppercase tracking-widest text-slate-500 hover:text-primary transition-colors">Login</a>
            <a href="/login" class="bg-primary text-white px-6 py-3 rounded-full text-[13px] font-bold uppercase tracking-widest hover:bg-secondary transition-all shadow-lg shadow-blue-100">
                Start Free
            </a>
            <!-- Hamburger Menu Button -->
            <button @click="mobileMenuOpen = !mobileMenuOpen" class="lg:hidden text-slate-600 hover:text-primary transition-colors focus:outline-none p-2">
                <i class="fa-solid" :class="mobileMenuOpen ? 'fa-xmark text-2xl' : 'fa-bars text-xl'"></i>
            </button>
        </div>
    </div>

    <!-- Mobile Navigation Menu -->
    <div x-show="mobileMenuOpen" 
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0 -translate-y-4"
         x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100 translate-y-0"
         x-transition:leave-end="opacity-0 -translate-y-4"
         @click.away="mobileMenuOpen = false"
         class="lg:hidden absolute top-20 left-0 w-full bg-white border-b border-slate-100 shadow-xl shadow-slate-200/20 py-4 flex flex-col px-6" style="display: none;">
        <nav class="flex flex-col gap-4 text-sm font-bold uppercase tracking-widest text-slate-500">
            <a @click="mobileMenuOpen = false" href="/#features" class="w-full py-2 hover:text-primary transition-colors">Features</a>
            <div class="w-full h-px bg-slate-50"></div>
            <a @click="mobileMenuOpen = false" href="/#templates" class="w-full py-2 hover:text-primary transition-colors">Templates</a>
            <div class="w-full h-px bg-slate-50"></div>
            <a @click="mobileMenuOpen = false" href="/#pricing" class="w-full py-2 hover:text-primary transition-colors">Pricing</a>
            <div class="w-full h-px bg-slate-50"></div>
            <a @click="mobileMenuOpen = false" href="/#about" class="w-full py-2 hover:text-primary transition-colors">About</a>
            <div class="w-full h-px bg-slate-50"></div>
            <a @click="mobileMenuOpen = false" href="/#contact" class="w-full py-2 hover:text-primary transition-colors">Contact</a>
            <div class="w-full h-px bg-slate-50 mt-2"></div>
            <a @click="mobileMenuOpen = false" href="/login" class="w-full py-3 text-center sm:hidden text-primary">Login</a>
        </nav>
    </div>
</header>
