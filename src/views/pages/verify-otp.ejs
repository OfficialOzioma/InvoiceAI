<main class="min-h-screen bg-[#F8FAFC] flex flex-col justify-center py-20 px-6 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-md text-center space-y-6 mb-8">
        <div class="w-16 h-16 bg-blue-50 border border-blue-100 rounded-2xl flex items-center justify-center mx-auto shadow-sm">
            <i data-lucide="mail" class="w-8 h-8 text-primary"></i>
        </div>
        <h2 class="text-4xl font-black tracking-tighter text-secondary">Verify email.</h2>
        <p class="text-sm text-slate-500 font-medium">We've sent a 6-digit code to your inbox.</p>
    </div>

    <div class="sm:mx-auto sm:w-full sm:max-w-md">
        <div class="bg-white py-12 px-8 shadow-2xl shadow-blue-500/5 sm:rounded-[40px] border border-slate-100 space-y-8">
            <form action="/auth/verify-otp" method="POST" class="space-y-8">
                <div class="flex justify-between gap-2">
                    <input type="text" maxlength="1" class="w-12 h-16 text-center text-2xl font-black bg-slate-50 border border-slate-100 rounded-xl outline-none focus:border-primary focus:bg-white transition-all">
                    <input type="text" maxlength="1" class="w-12 h-16 text-center text-2xl font-black bg-slate-50 border border-slate-100 rounded-xl outline-none focus:border-primary focus:bg-white transition-all">
                    <input type="text" maxlength="1" class="w-12 h-16 text-center text-2xl font-black bg-slate-50 border border-slate-100 rounded-xl outline-none focus:border-primary focus:bg-white transition-all">
                    <input type="text" maxlength="1" class="w-12 h-16 text-center text-2xl font-black bg-slate-50 border border-slate-100 rounded-xl outline-none focus:border-primary focus:bg-white transition-all">
                    <input type="text" maxlength="1" class="w-12 h-16 text-center text-2xl font-black bg-slate-50 border border-slate-100 rounded-xl outline-none focus:border-primary focus:bg-white transition-all">
                    <input type="text" maxlength="1" class="w-12 h-16 text-center text-2xl font-black bg-slate-50 border border-slate-100 rounded-xl outline-none focus:border-primary focus:bg-white transition-all">
                </div>

                <button type="submit" class="w-full bg-primary text-white py-5 rounded-xl font-bold text-xs uppercase tracking-widest hover:bg-secondary transition-all shadow-xl shadow-blue-100">
                    Verify Account
                </button>
            </form>

            <div class="text-center space-y-4">
                <p class="text-[11px] font-bold uppercase tracking-widest text-slate-400">
                    Didn't receive code? <a href="#" class="text-primary hover:text-secondary transition-colors">Resend Code</a>
                </p>
                <div>
                    <a href="/login" class="text-[11px] font-bold uppercase tracking-widest text-slate-400 hover:text-secondary transition-colors inline-flex items-center gap-2">
                        <i data-lucide="arrow-left" class="w-3 h-3"></i> Back to Sign In
                    </a>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    // Simple auto-focus for OTP inputs
    const inputs = document.querySelectorAll('input[maxlength="1"]');
    inputs.forEach((input, index) => {
        input.addEventListener('input', (e) => {
            if (e.target.value.length === 1 && index < inputs.length - 1) {
                inputs[index + 1].focus();
            }
        });
        input.addEventListener('keydown', (e) => {
            if (e.key === 'Backspace' && !e.target.value && index > 0) {
                inputs[index - 1].focus();
            }
        });
    });
</script>
