<div class="space-y-6 md:space-y-8">
    <!-- Header Area -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-indigo-50 border border-indigo-100 rounded-full text-indigo-600 text-[10px] font-bold tracking-widest uppercase mb-3">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"></span>
          </span>
          Workspace Active
        </div>
        <h1 class="text-2xl md:text-3xl font-black tracking-tight mb-1 text-slate-900 leading-none">Overview</h1>
        <p class="text-sm text-slate-500 font-medium">Your financial pulse at a glance.</p>
      </div>
      <div class="flex items-center gap-3 w-full md:w-auto">
        <a href="/invoices/wizard?method=ai" class="flex-1 md:flex-none justify-center bg-white border border-slate-200 text-slate-600 px-5 py-2.5 rounded-xl text-xs font-bold flex items-center gap-2 hover:bg-slate-50 hover:text-indigo-600 transition-all shadow-sm">
            <i data-lucide="sparkles" class="w-4 h-4"></i> Auto Generate
        </a>
        <a href="/invoices/wizard" class="flex-1 md:flex-none justify-center bg-slate-900 text-white px-5 py-2.5 rounded-xl text-xs font-bold flex items-center gap-2 hover:bg-slate-800 transition-all shadow-lg shadow-slate-900/20">
            <i data-lucide="plus" class="w-4 h-4"></i> New Invoice
        </a>
      </div>
    </div>

    <!-- Enhanced Stats Grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
        <!-- Total Revenue -->
        <div class="bg-gradient-to-br from-white to-slate-50 p-5 md:p-6 rounded-2xl border border-slate-100 shadow-sm relative overflow-hidden group">
            <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
                <i data-lucide="dollar-sign" class="w-16 h-16 text-emerald-600 transform group-hover:scale-110 transition-transform duration-500"></i>
            </div>
            <div class="flex items-center gap-2 mb-3">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-emerald-100 text-emerald-600">
                    <i data-lucide="trending-up" class="w-4 h-4"></i>
                </div>
                <div class="text-[10px] font-bold uppercase tracking-widest text-slate-500">Total Revenue</div>
            </div>
            <div class="text-2xl md:text-3xl font-black tracking-tighter text-slate-900 mb-2">$<%= stats.totalRevenue %></div>
            <div class="flex items-center gap-1.5 text-[11px] font-bold <%= stats.revenueIsUp ? 'text-emerald-600' : 'text-rose-600' %>">
                <i data-lucide="<%= stats.revenueIsUp ? 'arrow-up-right' : 'arrow-down-right' %>" class="w-3 h-3"></i>
                <%= stats.revenueTrend %> vs last month
            </div>
        </div>

        <!-- Outstanding -->
        <div class="bg-gradient-to-br from-white to-slate-50 p-5 md:p-6 rounded-2xl border border-slate-100 shadow-sm relative overflow-hidden group">
            <div class="flex items-center gap-2 mb-3">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-amber-100 text-amber-600">
                    <i data-lucide="clock" class="w-4 h-4"></i>
                </div>
                <div class="text-[10px] font-bold uppercase tracking-widest text-slate-500">Outstanding</div>
            </div>
            <div class="text-2xl md:text-3xl font-black tracking-tighter text-slate-900 mb-2">$<%= stats.outstanding %></div>
            <div class="flex items-center gap-1.5 text-[11px] font-bold <%= !stats.outstandingIsUp ? 'text-emerald-600' : 'text-rose-600' %>">
                <i data-lucide="<%= stats.outstandingIsUp ? 'arrow-up-right' : 'arrow-down-right' %>" class="w-3 h-3"></i>
                <%= stats.outstandingTrend %> vs last month
            </div>
        </div>

        <!-- Paid Invoices Count -->
        <div class="bg-gradient-to-br from-white to-slate-50 p-5 md:p-6 rounded-2xl border border-slate-100 shadow-sm relative overflow-hidden group">
            <div class="flex items-center gap-2 mb-3">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-blue-100 text-blue-600">
                    <i data-lucide="check-circle-2" class="w-4 h-4"></i>
                </div>
                <div class="text-[10px] font-bold uppercase tracking-widest text-slate-500">Invoices Paid</div>
            </div>
            <div class="text-2xl md:text-3xl font-black tracking-tighter text-slate-900 mb-2"><%= stats.paidInvoices %></div>
            <div class="flex items-center gap-1.5 text-[11px] font-bold <%= stats.paidIsUp ? 'text-emerald-600' : 'text-rose-600' %>">
                <i data-lucide="<%= stats.paidIsUp ? 'arrow-up-right' : 'arrow-down-right' %>" class="w-3 h-3"></i>
                <%= stats.paidTrend %> vs last month
            </div>
        </div>

        <!-- Overdue -->
        <div class="bg-gradient-to-br from-white to-slate-50 p-5 md:p-6 rounded-2xl border border-slate-100 shadow-sm relative overflow-hidden group">
            <div class="flex items-center gap-2 mb-3">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-rose-100 text-rose-600">
                    <i data-lucide="alert-circle" class="w-4 h-4"></i>
                </div>
                <div class="text-[10px] font-bold uppercase tracking-widest text-slate-500">Overdue</div>
            </div>
            <div class="text-2xl md:text-3xl font-black tracking-tighter text-slate-900 mb-2"><%= stats.overdueInvoices %></div>
            <div class="flex items-center gap-1.5 text-[11px] font-bold text-rose-600">
                <i data-lucide="arrow-up-right" class="w-3 h-3"></i>
                <%= stats.overdueTrend %> vs last month
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

    <!-- AI Insights Section -->
    <div x-data="{ 
        loading: false, 
        insights: null, 
        error: null,
        async fetchInsights() {
            this.loading = true;
            this.error = null;
            try {
                const res = await fetch('/invoices/insights');
                if (!res.ok) throw new Error('Failed to generate insights');
                this.insights = await res.json();
                this.$nextTick(() => {
                    if (window.lucide) window.lucide.createIcons();
                });
            } catch (e) {
                this.error = e.message;
            } finally {
                this.loading = false;
            }
        },
        downloadReport() {
            const element = document.getElementById('ai-report-template');
            
            const opt = {
                margin: 10,
                filename: 'invoice-ai-insights.pdf',
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2, useCORS: true },
                jsPDF: { unit: 'mm', format: 'a4', orientation: 'vertical' }
            };

            // Temporarily show for capture
            element.style.display = 'block';
            
            html2pdf().from(element).set(opt).save().finally(() => {
                element.style.display = 'none';
            });
        }
    }" class="bg-indigo-900 rounded-[32px] p-6 md:p-8 text-white relative overflow-hidden shadow-xl shadow-indigo-500/20">
        <div class="absolute -right-4 -top-4 w-64 h-64 bg-white opacity-[0.03] rounded-full blur-3xl pointer-events-none"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div class="space-y-2">
                <div class="inline-flex items-center gap-2 px-3 py-1 bg-white/10 rounded-full text-[10px] font-black uppercase tracking-widest backdrop-blur-md">
                    <i data-lucide="brain-circuit" class="w-3 h-3 text-indigo-200"></i>
                    AI Intelligence
                </div>
                <h3 class="text-xl font-black tracking-tight">Smart Business Insights</h3>
                <p class="text-xs text-indigo-200 font-medium max-w-md">Let our AI analyze your billing patterns and provide strategic recommendations.</p>
            </div>
            
            <div class="flex items-center gap-3">
                <button x-show="insights" 
                        @click="downloadReport"
                        class="bg-indigo-700 hover:bg-indigo-800 text-white p-3 rounded-2xl transition-all shadow-lg flex items-center gap-2 text-[10px] font-black uppercase tracking-widest border border-white/5">
                    <i data-lucide="download" class="w-4 h-4"></i>
                    PDF Report
                </button>
                <button @click="fetchInsights" 
                        :disabled="loading"
                        class="bg-white text-indigo-900 px-6 py-3 rounded-2xl text-xs font-black uppercase tracking-widest hover:bg-slate-100 transition-all flex items-center justify-center gap-2 shadow-lg disabled:opacity-50">
                    <template x-if="!loading">
                        <div class="flex items-center gap-2">
                            <i data-lucide="zap" class="w-4 h-4 text-indigo-600"></i>
                            Generate Insights
                        </div>
                    </template>
                    <template x-if="loading">
                        <div class="flex items-center gap-2">
                            <svg class="animate-spin h-4 w-4 text-indigo-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            Analyzing...
                        </div>
                    </template>
                </button>
            </div>
        </div>

        <template x-if="insights">
            <!-- Insights UI remains same -->
            <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-6 animate-in fade-in slide-in-from-top-4 duration-500">
                <div class="md:col-span-3 p-4 bg-white/5 border border-white/10 rounded-2xl">
                    <p class="text-sm font-bold italic text-indigo-100" x-text="'&quot;' + insights.summary + '&quot;'"></p>
                </div>
                
                <template x-for="insight in insights.insights">
                    <div class="bg-white/10 backdrop-blur-md p-5 rounded-2xl border border-white/5 space-y-3">
                        <div class="flex items-center gap-2">
                            <div class="w-6 h-6 rounded-lg bg-indigo-500/30 flex items-center justify-center">
                                <i :data-lucide="insight.type === 'trend' ? 'trending-up' : insight.type === 'risk' ? 'shield-alert' : 'lightbulb'" class="w-3.5 h-3.5 text-indigo-200"></i>
                            </div>
                            <span class="text-[9px] font-black uppercase tracking-widest text-indigo-300" x-text="insight.type"></span>
                        </div>
                        <p class="text-xs font-bold leading-relaxed" x-text="insight.text"></p>
                        <div class="pt-2 border-t border-white/5">
                            <p class="text-[10px] text-indigo-300 font-bold uppercase tracking-tight">Action:</p>
                            <p class="text-[10px] font-medium leading-tight mt-1" x-text="insight.action"></p>
                        </div>
                    </div>
                </template>

                <div class="md:col-span-3 flex items-center gap-4 p-4 rounded-2xl bg-indigo-800/50 border border-indigo-700">
                    <div class="w-12 h-12 rounded-xl bg-white/10 border border-white/10 flex flex-col items-center justify-center">
                        <span class="text-lg font-black tracking-tight" x-text="insights.healthScore"></span>
                        <span class="text-[7px] font-black uppercase">Score</span>
                    </div>
                    <div>
                        <p class="text-[10px] font-black uppercase tracking-widest text-indigo-300 mb-1">Financial Health Index</p>
                        <div class="w-64 h-1.5 bg-indigo-900/50 rounded-full overflow-hidden">
                            <div class="h-full bg-indigo-400 transition-all duration-1000" :style="'width: ' + insights.healthScore + '%'"></div>
                        </div>
                    </div>
                </div>
            </div>
        </template>
        
        <template x-if="error">
            <div class="mt-6 p-4 bg-rose-500/20 border border-rose-500/30 rounded-2xl text-xs font-bold text-rose-200 flex items-center gap-3">
                <i data-lucide="alert-triangle" class="w-4 h-4"></i>
                <span x-text="error"></span>
            </div>
        </template>

        <!-- Hidden PDF Template -->
        <div id="ai-report-template" style="display: none; padding: 40px; background: white; color: #1e293b; font-family: 'Inter', sans-serif;">
            <div style="display: flex; justify-between; items-center; border-bottom: 2px solid #f1f5f9; padding-bottom: 30px; margin-bottom: 40px;">
                <div style="flex: 1;">
                    <h1 style="font-size: 24px; font-weight: 900; color: #1e293b; margin: 0;">AI INSIGHTS REPORT</h1>
                    <p style="font-size: 12px; color: #64748b; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; margin-top: 5px;">Financial Analysis & Recommendations</p>
                </div>
                <div style="text-align: right;">
                    <div style="width: 40px; height: 40px; background: #3b82f6; border-radius: 8px; display: inline-flex; align-items: center; justify-content: center; color: white;">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                    </div>
                    <p style="font-size: 14px; font-weight: 800; color: #1e293b; margin: 5px 0 0 0;">Acme Corp</p>
                </div>
            </div>

            <div style="margin-bottom: 40px; background: #f8fafc; padding: 25px; border-radius: 16px; border: 1px solid #f1f5f9;">
                <h2 style="font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: 2px; color: #64748b; margin-bottom: 15px;">Executive Summary</h2>
                <p style="font-size: 14px; font-weight: 600; font-style: italic; color: #334155; line-height: 1.6;" x-text="insights ? insights.summary : ''"></p>
            </div>

            <div style="display: grid; grid-template-cols: 1fr; gap: 20px; margin-bottom: 40px;">
                <template x-for="(insight, index) in (insights ? insights.insights : [])">
                    <div style="background: white; border: 1px solid #f1f5f9; padding: 20px; border-radius: 12px;">
                        <div style="display: flex; items-center; gap: 10px; margin-bottom: 12px;">
                            <div style="padding: 4px 10px; background: #eff6ff; color: #3b82f6; font-size: 9px; font-weight: 900; border-radius: 4px; text-transform: uppercase;" x-text="insight.type"></div>
                        </div>
                        <p style="font-size: 13px; font-weight: 700; color: #1e293b; margin-bottom: 15px;" x-text="insight.text"></p>
                        <div style="background: #fafafa; padding: 12px; border-left: 3px solid #3b82f6; border-radius: 4px;">
                            <span style="font-size: 9px; font-weight: 900; color: #94a3b8; text-transform: uppercase;">Recommended Action:</span>
                            <p style="font-size: 11px; font-weight: 500; color: #475569; margin: 5px 0 0 0;" x-text="insight.action"></p>
                        </div>
                    </div>
                </template>
            </div>

            <div style="border-top: 1px solid #f1f5f9; padding-top: 30px; display: flex; align-items: center; justify-between;">
                <div>
                  <h3 style="font-size: 11px; font-weight: 900; color: #64748b; text-transform: uppercase;">Financial Health Score</h3>
                  <p style="font-size: 48px; font-weight: 900; color: #1e293b; margin: 0;" x-text="insights ? insights.healthScore : ''"></p>
                </div>
                <div style="text-align: right; color: #94a3b8; font-size: 10px; font-weight: 600;">
                    Generated on June 22, 2026<br>
                    by InvoiceAI Core
                </div>
            </div>
        </div>
    </div>

    <!-- Lower Section: Chart & Activity Grid -->
    <div class="grid lg:grid-cols-3 gap-6">
      
      <!-- Modern Chart Card -->
      <div class="lg:col-span-2 bg-white rounded-2xl p-6 md:p-8 border border-slate-100 shadow-sm flex flex-col">
         <div class="flex items-center justify-between mb-8">
           <div>
               <h3 class="font-bold text-sm text-slate-900 uppercase tracking-tight">Revenue Trajectory</h3>
               <p class="text-xs text-slate-500 mt-1 font-medium">Last 6 months performance</p>
           </div>
           <!-- Toggle pills (UI only) -->
           <div class="hidden sm:flex bg-slate-100 p-1 rounded-lg">
               <button class="px-3 py-1 text-[10px] font-bold uppercase tracking-widest rounded-md bg-white shadow-sm text-slate-900">Weekly</button>
               <button class="px-3 py-1 text-[10px] font-bold uppercase tracking-widest rounded-md text-slate-500 hover:text-slate-900 transition-colors">Monthly</button>
           </div>
         </div>
         
         <!-- Simulated SVG Bar Chart -> more modern generic styling -->
         <div class="h-[240px] w-full flex items-end justify-between gap-1 sm:gap-3 px-2 sm:px-6 relative group">
             
             <!-- Grid Lines -->
             <div class="absolute inset-x-0 bottom-0 top-0 flex flex-col justify-between pointer-events-none px-6">
                 <div class="border-b border-slate-100 w-full h-0"></div>
                 <div class="border-b border-slate-100 w-full h-0"></div>
                 <div class="border-b border-slate-100 w-full h-0"></div>
                 <div class="border-b border-slate-100 w-full h-0"></div>
                 <div class="border-b border-slate-900 w-full h-0"></div>
             </div>

             <!-- Bars -->
             <div class="relative flex-1 group/bar flex justify-center h-full items-end z-10 cursor-pointer">
                 <div class="absolute -top-10 opacity-0 group-hover/bar:opacity-100 transition-opacity bg-slate-900 text-white text-[10px] font-bold py-1 px-2 rounded">$4.2k</div>
                 <div class="w-full max-w-[40px] bg-slate-200 rounded-t-lg transition-all duration-500 group-hover/bar:bg-indigo-400" style="height: 40%"></div>
             </div>
             <div class="relative flex-1 group/bar flex justify-center h-full items-end z-10 cursor-pointer">
                 <div class="absolute -top-10 opacity-0 group-hover/bar:opacity-100 transition-opacity bg-slate-900 text-white text-[10px] font-bold py-1 px-2 rounded">$5.8k</div>
                 <div class="w-full max-w-[40px] bg-slate-200 rounded-t-lg transition-all duration-500 group-hover/bar:bg-indigo-400" style="height: 60%"></div>
             </div>
             <div class="relative flex-1 group/bar flex justify-center h-full items-end z-10 cursor-pointer">
                 <div class="absolute -top-10 opacity-0 group-hover/bar:opacity-100 transition-opacity bg-slate-900 text-white text-[10px] font-bold py-1 px-2 rounded">$3.1k</div>
                 <div class="w-full max-w-[40px] bg-slate-200 rounded-t-lg transition-all duration-500 group-hover/bar:bg-indigo-400" style="height: 30%"></div>
             </div>
             <div class="relative flex-1 group/bar flex justify-center h-full items-end z-10 cursor-pointer">
                 <div class="absolute -top-10 opacity-0 group-hover/bar:opacity-100 transition-opacity bg-slate-900 text-white text-[10px] font-bold py-1 px-2 rounded">$8.5k</div>
                 <div class="w-full max-w-[40px] bg-slate-300 rounded-t-lg transition-all duration-500 group-hover/bar:bg-indigo-500" style="height: 80%"></div>
             </div>
             <div class="relative flex-1 group/bar flex justify-center h-full items-end z-10 cursor-pointer">
                 <div class="absolute -top-10 opacity-0 group-hover/bar:opacity-100 transition-opacity bg-slate-900 text-white text-[10px] font-bold py-1 px-2 rounded">$7.2k</div>
                 <div class="w-full max-w-[40px] bg-slate-300 rounded-t-lg transition-all duration-500 group-hover/bar:bg-indigo-500" style="height: 70%"></div>
             </div>
             <div class="relative flex-1 group/bar flex justify-center h-full items-end z-10 cursor-pointer">
                 <div class="absolute -top-10 opacity-0 group-hover/bar:opacity-100 transition-opacity bg-slate-900 text-white text-[10px] font-bold py-1 px-2 rounded">$11.4k</div>
                 <!-- Highlighted current month -->
                 <div class="w-full max-w-[40px] bg-slate-900 rounded-t-lg shadow-lg shadow-indigo-500/20 transition-all duration-500" style="height: 95%"></div>
             </div>
         </div>
         <div class="flex justify-between mt-4 px-2 sm:px-6 text-[10px] font-bold text-slate-400 uppercase tracking-widest">
             <span class="flex-1 text-center">Nov</span>
             <span class="flex-1 text-center">Dec</span>
             <span class="flex-1 text-center">Jan</span>
             <span class="flex-1 text-center">Feb</span>
             <span class="flex-1 text-center">Mar</span>
             <span class="flex-1 text-center text-slate-900">Apr</span>
         </div>
      </div>

      <!-- Recent Activity Feed -->
      <div class="bg-white rounded-2xl p-6 md:p-8 border border-slate-100 shadow-sm flex flex-col">
          <div class="flex items-center justify-between mb-8">
            <h3 class="font-bold text-sm text-slate-900 uppercase tracking-tight">Latest Activity</h3>
            <a href="/invoices" class="text-[10px] font-bold text-indigo-600 hover:text-indigo-800 transition-colors uppercase tracking-widest hidden sm:block">View All</a>
          </div>
          
          <div class="space-y-6 flex-1">
            <% if (!invoices || invoices.length === 0) { %>
               <div class="py-10 text-center space-y-4">
                 <div class="w-14 h-14 bg-slate-50 border border-slate-100 rounded-full flex items-center justify-center mx-auto text-slate-300">
                   <i data-lucide="inbox" class="w-6 h-6"></i>
                 </div>
                 <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">No recent transactions</p>
               </div>
            <% } else { %>
              <% invoices.forEach((inv, i) => { %>
                <div class="flex items-center justify-between group cursor-pointer transition-all hover:bg-slate-50 -mx-3 px-3 py-2 rounded-xl">
                    <div class="flex items-center gap-3">
                      <!-- Contextual Icon based on status -->
                      <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 
                        <%= inv.status === 'Paid' ? 'bg-emerald-50 text-emerald-600' : 
                            inv.status === 'Pending' ? 'bg-amber-50 text-amber-600' : 'bg-rose-50 text-rose-600' %>">
                        <i data-lucide="<%= inv.status === 'Paid' ? 'check-circle-2' : inv.status === 'Pending' ? 'clock' : 'alert-circle' %>" class="w-4 h-4"></i>
                      </div>
                      <div class="overflow-hidden">
                        <div class="font-bold text-sm text-slate-900 truncate"><%= inv.clientName %></div>
                        <div class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mt-0.5 truncate"><%= inv.invoiceNumber %></div>
                      </div>
                    </div>
                    <div class="text-right shrink-0 ml-2">
                       <div class="font-black text-sm tracking-tight text-slate-900">$<%= inv.total %></div>
                       <div class="text-[9px] font-bold uppercase tracking-widest mt-0.5 
                         <%= inv.status === 'Paid' ? 'text-emerald-600' : 
                             inv.status === 'Pending' ? 'text-amber-600' : 'text-rose-600' %>">
                         <%= inv.status %>
                       </div>
                    </div>
                  </div>
              <% }) %>
            <% } %>
          </div>

          <a href="/invoices" class="mt-6 flex sm:hidden items-center justify-center gap-2 text-[10px] font-bold uppercase tracking-widest text-slate-600 bg-slate-50 py-3 rounded-xl hover:text-slate-900 transition-colors w-full">
            View All Activity
          </a>
      </div>
    </div>
</div>

