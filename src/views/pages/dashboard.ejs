<div class="space-y-8">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
      <div>
        <h1 class="text-2xl font-extrabold tracking-tight mb-1 text-secondary">Operational Overview</h1>
        <p class="text-sm text-slate-500 font-medium">Real-time revenue monitoring and activity.</p>
      </div>
      <div class="flex items-center gap-3">
        <a href="/invoices/ai" class="bg-indigo-50 border border-indigo-100 text-indigo-600 px-5 py-2.5 rounded-xl text-xs font-bold flex items-center gap-2 hover:bg-indigo-100 transition-all shadow-sm">
            <i data-lucide="sparkles" class="w-4 h-4"></i> Generate via AI
        </a>
        <a href="/invoices/new" class="bg-primary text-white px-5 py-2.5 rounded-xl text-xs font-bold flex items-center gap-2 hover:bg-secondary transition-all shadow-lg shadow-blue-500/20">
            <i data-lucide="plus" class="w-4 h-4"></i> New Invoice
        </a>
      </div>
    </div>

    <!-- Main Stats Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm shadow-slate-200/50">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4 bg-blue-50 border border-blue-100">
                <i data-lucide="file-text" class="w-5 h-5 text-primary"></i>
            </div>
            <div class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">Total Invoices</div>
            <div class="text-2xl font-extrabold font-mono tracking-tight text-secondary">142</div>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm shadow-slate-200/50">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4 bg-emerald-50 border border-emerald-100">
                <i data-lucide="check-circle-2" class="w-5 h-5 text-emerald-600"></i>
            </div>
            <div class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">Paid Invoices</div>
            <div class="text-2xl font-extrabold font-mono tracking-tight text-secondary">98</div>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm shadow-slate-200/50">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4 bg-amber-50 border border-amber-100">
                <i data-lucide="clock" class="w-5 h-5 text-amber-600"></i>
            </div>
            <div class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">Unpaid Invoices</div>
            <div class="text-2xl font-extrabold font-mono tracking-tight text-secondary">32</div>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm shadow-slate-200/50">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4 bg-rose-50 border border-rose-100">
                <i data-lucide="alert-circle" class="w-5 h-5 text-rose-600"></i>
            </div>
            <div class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">Overdue Invoices</div>
            <div class="text-2xl font-extrabold font-mono tracking-tight text-secondary">12</div>
        </div>
    </div>

    <div class="grid xl:grid-cols-3 gap-6">
      <!-- Chart Card (Placeholder for Revenue Summary) -->
      <div class="xl:col-span-2 bg-white rounded-2xl p-8 border border-slate-100 shadow-sm shadow-slate-200/50 relative overflow-hidden flex flex-col justify-between">
         <div class="flex items-center justify-between mb-8">
           <h3 class="font-bold text-sm text-secondary uppercase tracking-tight">Revenue Distribution</h3>
           <div class="text-[10px] font-bold text-primary italic uppercase tracking-widest">Live Feed</div>
         </div>
         
         <div class="h-[280px] w-full flex items-end gap-2 px-4">
             <!-- Placeholder chart using divs -->
             <div class="flex-1 bg-primary rounded-t-lg" style="height: 60%"></div>
             <div class="flex-1 bg-primary/60 rounded-t-lg" style="height: 80%"></div>
             <div class="flex-1 bg-primary rounded-t-lg" style="height: 40%"></div>
             <div class="flex-1 bg-primary/60 rounded-t-lg" style="height: 90%"></div>
             <div class="flex-1 bg-primary rounded-t-lg" style="height: 50%"></div>
         </div>
         <div class="flex justify-between mt-4 text-[10px] font-bold text-muted uppercase">
             <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span>
         </div>
      </div>

      <!-- Recent Activity Card -->
      <div class="bg-white rounded-2xl p-8 border border-slate-100 shadow-sm shadow-slate-200/50 flex flex-col">
          <div class="flex items-center justify-between mb-6">
            <h3 class="font-bold text-sm text-secondary uppercase tracking-tight">Recent Activity</h3>
            <span class="px-2 py-1 bg-slate-100 rounded text-[9px] font-bold text-slate-500 uppercase tracking-widest">Live</span>
          </div>
          <div class="space-y-5 flex-1">
            <% if (invoices.length === 0) { %>
               <div class="py-10 text-center space-y-4">
                 <div class="w-14 h-14 bg-slate-50 rounded-full flex items-center justify-center mx-auto text-slate-300">
                   <i data-lucide="file-text" class="w-7 h-7"></i>
                 </div>
                 <p class="text-[10px] font-bold text-muted uppercase tracking-widest">Quiet in the workspace</p>
               </div>
            <% } else { %>
              <% invoices.forEach(inv => { %>
                <div class="flex items-start justify-between group cursor-pointer transition-all hover:translate-x-1">
                    <div class="flex gap-3">
                      <div class="w-9 h-9 rounded-lg flex items-center justify-center bg-slate-50 text-slate-400">
                        <i data-lucide="file-text" class="w-4 h-4"></i>
                      </div>
                      <div>
                        <div class="font-bold text-xs text-secondary"><%= inv.invoiceNumber %></div>
                        <div class="text-[9px] text-muted font-bold uppercase tracking-tight">2 minutes ago</div>
                      </div>
                    </div>
                    <div class="text-right">
                       <div class="font-bold text-xs tracking-tight text-secondary">$<%= inv.total %></div>
                       <div class="text-[8px] font-extrabold uppercase tracking-widest text-slate-400">
                         <%= inv.status %>
                       </div>
                    </div>
                  </div>
              <% }) %>
            <% } %>
          </div>

          <a href="/invoices" class="mt-6 flex items-center justify-center gap-2 text-[9px] font-bold uppercase tracking-widest text-primary hover:text-secondary transition-colors pt-4 border-t border-slate-50 w-full">
            View Ledger <i data-lucide="arrow-up-right" class="w-3.5 h-3.5"></i>
          </a>
      </div>
    </div>
</div>
