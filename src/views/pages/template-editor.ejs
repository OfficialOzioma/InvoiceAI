<!-- CodeMirror CSS & JS -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/codemirror.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/theme/material-darker.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/codemirror.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/mode/xml/xml.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/mode/javascript/javascript.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/mode/css/css.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/mode/htmlmixed/htmlmixed.min.js"></script>

<style>
  /* Local overrides for editor */
  .CodeMirror {
    height: 100%;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, monospace;
    font-size: 14px;
    background: transparent;
  }
  .cm-s-material-darker.CodeMirror {
    background-color: #0f172a; /* Tailwind slate-900 */
    color: #e2e8f0;
  }
</style>

<form action="/templates/<%= typeof template !== 'undefined' && template ? 'update/' + template.id : 'save' %>" method="POST" id="template-editor-form" class="h-full flex flex-col" x-data="templateWorkspace()">
    <!-- Top Control Bar -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6 bg-white p-4 rounded-2xl border border-slate-200 shadow-sm">
        <div class="flex-1 max-w-xl">
            <label for="template_name" class="sr-only">Template Name</label>
            <input type="text" id="template_name" name="template_name" x-model="templateName" placeholder="Enter Template Name..." class="w-full bg-transparent border-0 font-extrabold text-xl text-secondary placeholder-slate-300 focus:ring-0 p-0 outline-none" required>
        </div>
        
        <div class="flex items-center gap-3">
            <button type="button" @click="resetTemplate()" class="px-4 py-2 text-sm font-bold text-slate-500 hover:text-slate-700 bg-slate-100 hover:bg-slate-200 rounded-lg transition-colors flex items-center gap-2">
                <i data-lucide="rotate-ccw" class="w-4 h-4"></i> Reset
            </button>
            <button type="button" @click="formatCode()" class="px-4 py-2 text-sm font-bold text-slate-500 hover:text-slate-700 bg-slate-100 hover:bg-slate-200 rounded-lg transition-colors flex items-center gap-2">
                <i data-lucide="align-left" class="w-4 h-4"></i> Format
            </button>
            <button type="submit" class="bg-primary text-white hover:bg-secondary px-6 py-2 rounded-lg text-sm font-bold flex items-center gap-2 transition-colors shadow-lg shadow-blue-100 disabled:opacity-50 disabled:cursor-not-allowed" :disabled="!isValid">
                <i data-lucide="save" class="w-4 h-4"></i> Save Template
            </button>
        </div>
    </div>

    <!-- Hidden Textarea for Form Submission -->
    <textarea id="template_code" name="template_code" x-ref="hiddenCode" style="display: none;"></textarea>

    <!-- Mobile view toggle -->
    <div class="flex lg:hidden bg-slate-100 p-1 rounded-lg mb-4">
         <button type="button" @click="mobileView = 'editor'" :class="mobileView === 'editor' ? 'bg-white shadow-sm text-primary' : 'text-slate-500'" class="flex-1 py-2 text-sm font-bold rounded-md transition-all">Editor</button>
         <button type="button" @click="mobileView = 'preview'" :class="mobileView === 'preview' ? 'bg-white shadow-sm text-primary' : 'text-slate-500'" class="flex-1 py-2 text-sm font-bold rounded-md transition-all">Preview</button>
    </div>

    <!-- Main Workspace (Dual Panel) -->
    <div class="flex-1 flex flex-col lg:flex-row min-h-0 gap-6">
        
        <!-- Left Panel: Code Editor -->
        <div class="flex-[3] flex flex-col bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden shadow-xl" x-show="mobileView === 'editor' || window.innerWidth >= 1024">
            <!-- Editor Header -->
            <div class="bg-slate-950 px-4 py-2 flex justify-between items-center border-b border-slate-800">
                <div class="flex items-center gap-2 text-slate-400 text-xs font-mono uppercase tracking-widest">
                    <i data-lucide="code-2" class="w-4 h-4"></i> HTML & EJS
                </div>
                <div class="flex items-center gap-3 text-xs text-slate-500" x-show="validationWarnings.length > 0">
                    <span class="text-orange-400 flex items-center gap-1 font-bold"><i data-lucide="alert-triangle" class="w-3 h-3"></i> Missing required vars</span>
                </div>
                <div class="flex items-center gap-3 text-xs text-slate-500" x-show="validationWarnings.length === 0 && !hasSyntaxError">
                    <span class="text-teal-400 flex items-center gap-1 font-bold"><i data-lucide="check-circle" class="w-3 h-3"></i> Valid</span>
                </div>
            </div>
            
            <!-- CodeMirror Target -->
            <div x-ref="editorContainer" class="flex-1 w-full relative"></div>
            
            <!-- Helper Panel (Drawer) -->
            <div class="border-t border-slate-800 bg-slate-950 text-slate-300">
                <button type="button" @click="showHelpers = !showHelpers" class="w-full px-4 py-3 flex items-center justify-between text-xs font-bold uppercase tracking-widest hover:text-white transition-colors">
                    <span class="flex items-center gap-2"><i data-lucide="terminal-square" class="w-4 h-4"></i> Variables Cheatsheet</span>
                    <i data-lucide="chevron-up" class="w-4 h-4 transition-transform" :class="showHelpers ? 'rotate-180' : ''"></i>
                </button>
                <div x-show="showHelpers" x-transition class="p-4 bg-slate-900 border-t border-slate-800 text-xs font-mono grid grid-cols-2 lg:grid-cols-4 gap-4 max-h-64 overflow-y-auto">
                    <!-- Business Data -->
                    <div>
                         <h4 class="text-emerald-400 font-bold mb-2 uppercase tracking-wide text-[10px]">Business Data</h4>
                         <ul class="space-y-1">
                             <li><code class="cursor-pointer hover:text-white transition-colors" @click="insertCode('<%%= business_name %>')">&lt;%= business_name %&gt;</code></li>
                         </ul>
                    </div>
                    <!-- Client Data -->
                    <div>
                         <h4 class="text-emerald-400 font-bold mb-2 uppercase tracking-wide text-[10px]">Client Data</h4>
                         <ul class="space-y-1">
                             <li><code class="cursor-pointer hover:text-white transition-colors" @click="insertCode('<%%= client_name %>')">&lt;%= client_name %&gt;</code></li>
                         </ul>
                    </div>
                    <!-- Metadata -->
                    <div>
                         <h4 class="text-emerald-400 font-bold mb-2 uppercase tracking-wide text-[10px]">Metadata</h4>
                         <ul class="space-y-1">
                             <li><code class="cursor-pointer hover:text-white transition-colors" @click="insertCode('<%%= invoice_number %>')">&lt;%= invoice_number %&gt;</code></li>
                             <li><code class="cursor-pointer hover:text-white transition-colors" @click="insertCode('<%%= date %>')">&lt;%= date %&gt;</code></li>
                         </ul>
                    </div>
                    <!-- Totals -->
                    <div>
                         <h4 class="text-emerald-400 font-bold mb-2 uppercase tracking-wide text-[10px]">Totals & Notes</h4>
                         <ul class="space-y-1">
                             <li><code class="cursor-pointer hover:text-white transition-colors" @click="insertCode('<%%= total_amount %>')">&lt;%= total_amount %&gt;</code></li>
                         </ul>
                    </div>
                    
                    <!-- Loop Example (Spans Full Width) -->
                    <div class="col-span-2 lg:col-span-4 mt-2 p-3 bg-slate-950 rounded border border-slate-800">
                        <h4 class="text-emerald-400 font-bold mb-2 uppercase tracking-wide text-[10px]">Mapping Items Array (Example)</h4>
                        <pre class="bg-slate-900 p-2 rounded text-slate-400 overflow-x-auto"><code class="cursor-pointer hover:text-white transition-colors" @click="insertItemsLoop()">&lt;% items.forEach(function(item) { %&gt;
  &lt;tr&gt;
    &lt;td&gt;&lt;%= item.description %&gt;&lt;/td&gt;
    &lt;td&gt;&lt;%= item.quantity %&gt;&lt;/td&gt;
    &lt;td&gt;&lt;%= item.price %&gt;&lt;/td&gt;
    &lt;td&gt;&lt;%= item.total %&gt;&lt;/td&gt;
  &lt;/tr&gt;
&lt;% }); %&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Panel: Live Preview -->
        <div class="flex-[2] flex flex-col bg-slate-50 border border-slate-200 rounded-2xl overflow-hidden shadow-inner relative" x-show="mobileView === 'preview' || window.innerWidth >= 1024">
            <div class="bg-white border-b border-slate-200 px-4 py-2 flex items-center justify-between shadow-sm z-10">
                <h3 class="font-bold text-xs text-slate-500 uppercase tracking-widest flex items-center gap-2">
                    <i data-lucide="eye" class="w-4 h-4"></i> Live Rendering
                </h3>
                <!-- Spinner for loading state -->
                <div x-show="isRendering" class="w-4 h-4 border-2 border-slate-300 border-t-primary rounded-full animate-spin"></div>
            </div>
            
            <div class="flex-1 bg-slate-200/50 relative overflow-hidden flex flex-col items-center justify-start p-4 lg:p-8">
                 <!-- Invoice Paper Wrapper -->
                 <div class="w-full aspect-[1/1.4] bg-white shadow-xl shadow-slate-300 border border-slate-200 relative">
                     <!-- Content Iframe -->
                     <iframe x-ref="previewFrame" class="absolute inset-0 w-full h-full border-0 pointer-events-none" sandbox="allow-same-origin"></iframe>
                 </div>
            </div>
        </div>
        
    </div>
</form>

<script>
const DEFAULT_TEMPLATE = `<div style="font-family: Arial, sans-serif; padding: 40px; color: #333; max-width: 800px; margin: 0 auto; box-sizing: border-box;">
  <!-- Header -->
  <div style="display: flex; justify-content: space-between; border-bottom: 2px solid #eee; padding-bottom: 20px;">
    <div>
      <h1 style="margin: 0; color: #1e3a8a;"><%%= business_name %></h1>
    </div>
    <div style="text-align: right;">
      <h2 style="margin: 0; font-size: 24px; color: #333;">INVOICE</h2>
      <p style="margin: 5px 0 0; color: #666; font-size: 14px;">#<%%= invoice_number %></p>
      <p style="margin: 5px 0 0; color: #666; font-size: 14px;">Date: <%%= date %></p>
    </div>
  </div>

  <!-- Client Section -->
  <div style="margin: 40px 0;">
    <p style="font-size: 12px; color: #666; text-transform: uppercase; font-weight: bold; margin-bottom: 5px;">Billed To:</p>
    <p style="font-size: 16px; margin: 0;"><%%= client_name %></p>
  </div>

  <!-- Items Table -->
  <table style="width: 100%; border-collapse: collapse; margin-bottom: 40px;">
    <thead>
      <tr style="background: #f8fafc;">
        <th style="padding: 12px; text-align: left; border-bottom: 2px solid #e2e8f0; font-size: 12px; color: #64748b; text-transform: uppercase;">Description</th>
        <th style="padding: 12px; text-align: right; border-bottom: 2px solid #e2e8f0; width: 80px; font-size: 12px; color: #64748b; text-transform: uppercase;">Qty</th>
        <th style="padding: 12px; text-align: right; border-bottom: 2px solid #e2e8f0; width: 100px; font-size: 12px; color: #64748b; text-transform: uppercase;">Price</th>
        <th style="padding: 12px; text-align: right; border-bottom: 2px solid #e2e8f0; width: 120px; font-size: 12px; color: #64748b; text-transform: uppercase;">Total</th>
      </tr>
    </thead>
    <tbody>
      <%% items.forEach(function(item) { %>
      <tr>
        <td style="padding: 12px; border-bottom: 1px solid #f1f5f9; font-size: 14px;"><%%= item.description %></td>
        <td style="padding: 12px; text-align: right; border-bottom: 1px solid #f1f5f9; font-size: 14px;"><%%= item.quantity %></td>
        <td style="padding: 12px; text-align: right; border-bottom: 1px solid #f1f5f9; font-size: 14px;">$<%%= Number(item.price).toFixed(2) %></td>
        <td style="padding: 12px; text-align: right; border-bottom: 1px solid #f1f5f9; font-size: 14px; font-weight: bold;">$<%%= Number(item.total).toFixed(2) %></td>
      </tr>
      <%% }); %>
    </tbody>
  </table>

  <!-- Totals Section -->
  <div style="display: flex; justify-content: flex-end;">
    <div style="width: 300px;">
      <div style="display: flex; justify-content: space-between; padding: 16px; background: #f8fafc; font-weight: bold; font-size: 18px; border-radius: 8px;">
        <span>Total Due:</span>
        <span style="color: #1e3a8a;"><%%= total_amount %></span>
      </div>
    </div>
  </div>

  <!-- Notes Section -->
  <div style="margin-top: 60px; padding-top: 20px; border-top: 1px solid #eee; font-size: 12px; color: #94a3b8; text-align: center;">
    <p style="margin: 0;">Thank you for your business. Please remit payment within 30 days.</p>
  </div>
</div>`;

function templateWorkspace() {
    return {
        templateName: '<%= typeof template !== "undefined" && template ? template.name : "" %>',
        // Load initial code from backend template if available, else default
        initialCode: `<%- typeof template !== "undefined" && template ? template.content.replace(/`/g, '\\`') : "" %>`,
        editor: null,
        mobileView: 'editor',
        showHelpers: true,
        previewTimeout: null,
        isRendering: false,
        hasSyntaxError: false,
        validationWarnings: [],
        
        get isValid() {
            return this.templateName.trim().length > 0 && !this.hasSyntaxError;
        },

        init() {
            // Set initial state based on server injection or DEFAULT_TEMPLATE
            const startingCode = this.initialCode || DEFAULT_TEMPLATE;
            this.$refs.hiddenCode.value = startingCode;

            // Initialize CodeMirror instance
            this.editor = CodeMirror(this.$refs.editorContainer, {
                value: startingCode,
                mode: "htmlmixed",
                theme: "material-darker",
                lineNumbers: true,
                styleActiveLine: true,
                matchBrackets: true,
                indentUnit: 2,
                tabSize: 2,
                autoCloseTags: true,
                lineWrapping: true
            });

            // Listen to changes and sync with hidden textarea + trigger preview
            this.editor.on('change', () => {
                const code = this.editor.getValue();
                this.$refs.hiddenCode.value = code;
                this.validateCode(code);
                this.debouncedRender(code);
            });

            // Initial manual render
            this.validateCode(startingCode);
            this.forceRender(startingCode);
            
            // Handle Form submission locally for this mock
            document.getElementById('template-editor-form').addEventListener('submit', (e) => {
                 e.preventDefault();
                 alert('Form Submitted successfully\\nName: ' + this.templateName + '\\nSize: ' + this.editor.getValue().length + ' bytes');
                 window.location.href = '/templates';
            });
        },

        resetTemplate() {
            if(confirm('Are you sure you want to reset the editor to the base structure? All changes will be lost.')) {
                this.editor.setValue(DEFAULT_TEMPLATE);
            }
        },

        formatCode() {
            // Very basic formatter using CodeMirror internals (just auto indent)
            const totalLines = this.editor.lineCount();
            for (let i = 0; i < totalLines; i++) {
                 this.editor.indentLine(i, "smart");
            }
        },

        insertCode(codeStr) {
            const doc = this.editor.getDoc();
            const cursor = doc.getCursor();
            doc.replaceRange(codeStr, cursor);
            this.editor.focus();
        },
        
        insertItemsLoop() {
            const loopCode = `<%% items.forEach(function(item) { %>\n  <tr>\n    <td><%%= item.description %></td>\n    <td><%%= item.quantity %></td>\n    <td>$<%%= Number(item.price).toFixed(2) %></td>\n    <td>$<%%= Number(item.total).toFixed(2) %></td>\n  </tr>\n<%% }); %>`;
            this.insertCode(loopCode);
        },

        validateCode(code) {
           const warnings = [];
           if(!code.includes('<%%= invoice_number %>')) warnings.push('invoice_number');
           if(!code.includes('<%%= total_amount %>')) warnings.push('total_amount');
           if(!code.includes('items.forEach')) warnings.push('items loop');
           this.validationWarnings = warnings;
        },

        debouncedRender(code) {
            this.isRendering = true;
            clearTimeout(this.previewTimeout);
            this.previewTimeout = setTimeout(() => {
                this.forceRender(code);
            }, 800);
        },

        async forceRender(code) {
            this.isRendering = true;
            try {
                const response = await fetch('/templates/preview-raw', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ code })
                });
                
                const html = await response.text();
                
                // Track if it's an error block
                this.hasSyntaxError = html.includes('EJS Syntax Error');

                // Render in iframe securely using Blob
                const blob = new Blob([html], {type: 'text/html;charset=utf-8'});
                this.$refs.previewFrame.src = URL.createObjectURL(blob);
            } catch(e) {
                console.error(e);
            } finally {
                this.isRendering = false;
            }
        }
    }
}
</script>
