<div x-data="{ 
    tab: 'general',
    settings: {
        businessName: 'My Awesome Workspace',
        currency: 'USD',
        taxRate: 10,
        logo: null,
        address: '123 Tech Lane, Silicon Valley',
        email: 'hello@myworkspace.com'
    },
    save() {
        alert('Settings saved successfully!');
    },
    handleLogo(e) {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = (f) => this.settings.logo = f.target.result;
            reader.readAsDataURL(file);
        }
    }
}" class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-extrabold tracking-tight mb-1 text-secondary">Settings</h1>
        <p class="text-sm text-slate-500 font-medium">Manage business details, payment configurations, and workspace preferences.</p>
      </div>
      <button @click="save" class="bg-primary text-white px-8 py-2.5 rounded-xl text-xs font-bold hover:bg-secondary transition-all shadow-lg shadow-blue-500/20">
        Save Changes
      </button>
    </div>

    <!-- Tabs Navigation -->
    <div class="flex items-center gap-1 bg-white p-1 rounded-2xl border border-slate-100 shadow-sm w-fit overflow-x-auto max-w-full">
        <button @click="tab = 'general'" :class="tab === 'general' ? 'bg-slate-900 text-white shadow-md' : 'text-slate-500 hover:text-slate-900'" class="px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all whitespace-nowrap">General</button>
        <button @click="tab = 'business'" :class="tab === 'business' ? 'bg-slate-900 text-white shadow-md' : 'text-slate-500 hover:text-slate-900'" class="px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all whitespace-nowrap">Business Info</button>
        <button @click="tab = 'payments'" :class="tab === 'payments' ? 'bg-slate-900 text-white shadow-md' : 'text-slate-500 hover:text-slate-900'" class="px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all whitespace-nowrap">Payment Gateway</button>
        <button @click="tab = 'team'" :class="tab === 'team' ? 'bg-slate-900 text-white shadow-md' : 'text-slate-500 hover:text-slate-900'" class="px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all whitespace-nowrap">Team members</button>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 space-y-6">
            <!-- General View -->
            <div x-show="tab === 'general'" x-transition class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
                <div class="p-8 border-b border-slate-50">
                    <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest">Workspace Preferences</h3>
                    <p class="text-xs text-slate-400 font-medium mt-1">Configure global defaults for your workspace.</p>
                </div>
                <div class="p-8 space-y-6">
                    <div class="grid md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                             <label class="text-[10px] font-bold uppercase tracking-widest text-slate-400">Workspace Name</label>
                             <input type="text" x-model="settings.businessName" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl text-sm focus:bg-white focus:border-primary transition-all outline-none">
                        </div>
                        <div class="space-y-2">
                             <label class="text-[10px] font-bold uppercase tracking-widest text-slate-400">Default Currency</label>
                             <select x-model="settings.currency" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl text-sm focus:bg-white focus:border-primary transition-all outline-none appearance-none">
                                <option value="USD">USD - US Dollar ($)</option>
                                <option value="EUR">EUR - Euro (€)</option>
                                <option value="GBP">GBP - British Pound (£)</option>
                                <option value="NGN">NGN - Nigerian Naira (₦)</option>
                             </select>
                        </div>
                    </div>
                    <div class="space-y-2">
                         <label class="text-[10px] font-bold uppercase tracking-widest text-slate-400">Default Tax Rate (%)</label>
                         <input type="number" x-model="settings.taxRate" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl text-sm focus:bg-white focus:border-primary transition-all outline-none">
                    </div>
                </div>
            </div>

            <!-- Business View -->
            <div x-show="tab === 'business'" x-transition class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
                <div class="p-8 border-b border-slate-50">
                    <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest">Business Branding</h3>
                    <p class="text-xs text-slate-400 font-medium mt-1">This information will appear on all your outgoing invoices.</p>
                </div>
                <div class="p-8 space-y-8">
                    <div class="flex flex-col md:flex-row gap-8 items-start">
                        <div class="space-y-4">
                            <label class="text-[10px] font-bold uppercase tracking-widest text-slate-400 block">Company Logo</label>
                            <div class="relative group">
                                <div class="w-32 h-32 rounded-3xl bg-slate-50 border-2 border-dashed border-slate-200 flex items-center justify-center overflow-hidden">
                                    <template x-if="!settings.logo">
                                        <i data-lucide="image" class="w-8 h-8 text-slate-300"></i>
                                    </template>
                                    <template x-if="settings.logo">
                                        <img :src="settings.logo" class="w-full h-full object-contain p-2">
                                    </template>
                                </div>
                                <input type="file" @change="handleLogo" class="absolute inset-0 opacity-0 cursor-pointer">
                                <div class="absolute -bottom-2 -right-2 w-8 h-8 bg-primary text-white rounded-xl flex items-center justify-center shadow-lg pointer-events-none group-hover:scale-110 transition-transform">
                                    <i data-lucide="camera" class="w-4 h-4"></i>
                                </div>
                            </div>
                        </div>
                        <div class="flex-1 space-y-6 w-full">
                            <div class="space-y-2">
                                 <label class="text-[10px] font-bold uppercase tracking-widest text-slate-400">Business Email</label>
                                 <input type="email" x-model="settings.email" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl text-sm focus:bg-white focus:border-primary transition-all outline-none">
                            </div>
                            <div class="space-y-2">
                                 <label class="text-[10px] font-bold uppercase tracking-widest text-slate-400">Business Address</label>
                                 <textarea x-model="settings.address" rows="3" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl text-sm focus:bg-white focus:border-primary transition-all outline-none resize-none"></textarea>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Team View (Mock Up) -->
            <div x-show="tab === 'team'" x-transition class="space-y-6">
                <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
                    <div class="p-8 border-b border-slate-50 flex justify-between items-center">
                        <div>
                            <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest">Team Members</h3>
                            <p class="text-xs text-slate-400 font-medium mt-1">Invite colleagues to help manage invoices.</p>
                        </div>
                        <button class="px-4 py-2 bg-blue-50 text-primary rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-blue-100 transition-all">Invite +</button>
                    </div>
                    <div class="divide-y divide-slate-50">
                        <div class="p-6 flex items-center gap-4">
                            <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center font-bold text-slate-400 text-xs">JD</div>
                            <div class="flex-1">
                                <p class="text-sm font-bold text-slate-900">John Doe (You)</p>
                                <p class="text-[10px] text-slate-400 font-bold uppercase">Owner</p>
                            </div>
                        </div>
                        <div class="p-6 flex items-center gap-4 opacity-50">
                            <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center font-bold text-slate-400 text-xs">AS</div>
                            <div class="flex-1">
                                <p class="text-sm font-bold text-slate-900">Alice Smith</p>
                                <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest italic">Pending Invite...</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="bg-blue-50 rounded-3xl p-8 border border-blue-100">
                    <div class="flex gap-4">
                        <div class="w-10 h-10 bg-white rounded-xl flex items-center justify-center text-primary shadow-sm ring-4 ring-blue-500/5">
                            <i data-lucide="crown" class="w-5 h-5"></i>
                        </div>
                        <div class="flex-1">
                            <h4 class="text-sm font-black text-slate-900 tracking-tight mb-1">Upgrade for Multi-user</h4>
                            <p class="text-xs text-slate-500 leading-relaxed">Collaborate with your team seamlessly. Get advanced permissions and role-based access control with our Scale plan.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Payments View -->
            <div x-show="tab === 'payments'" x-transition class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
                <div class="p-8 border-b border-slate-50">
                    <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest">Payout Settings</h3>
                    <p class="text-xs text-slate-400 font-medium mt-1">Connect payment providers to get paid automatically.</p>
                </div>
                <div class="p-8 space-y-8">
                    <div class="flex items-center justify-between p-6 bg-slate-50 rounded-2xl border border-slate-100">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center">
                                <img src="https://picsum.photos/seed/stripe/40/40" class="w-8 h-8 rounded" alt="Stripe">
                            </div>
                            <div>
                                <p class="text-sm font-black text-slate-900 tracking-tight">Stripe Connect</p>
                                <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">Global Credit Cards & Apple Pay</p>
                            </div>
                        </div>
                        <button class="bg-slate-900 text-white px-6 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-slate-800 transition-all">Connect</button>
                    </div>
                    <div class="flex items-center justify-between p-6 bg-slate-50 rounded-2xl border border-slate-100">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center">
                                <img src="https://picsum.photos/seed/paystack/40/40" class="w-8 h-8 rounded" alt="Paystack">
                            </div>
                            <div>
                                <p class="text-sm font-black text-slate-900 tracking-tight">Paystack</p>
                                <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">Bank Transfers & Local Wallets</p>
                            </div>
                        </div>
                        <button class="bg-slate-900 text-white px-6 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-slate-800 transition-all">Connect</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar / Context -->
        <div class="space-y-6">
            <div class="bg-slate-900 text-white rounded-[32px] p-8 shadow-xl shadow-slate-900/20 relative overflow-hidden">
                <div class="absolute -right-4 -top-4 w-32 h-32 bg-white opacity-[0.03] rounded-full blur-3xl"></div>
                <div class="relative z-10">
                    <div class="w-12 h-12 bg-white/10 rounded-2xl flex items-center justify-center mb-6 backdrop-blur-md">
                        <i data-lucide="shield-check" class="w-6 h-6 text-white"></i>
                    </div>
                    <h3 class="text-lg font-black tracking-tight mb-3">Security & Privacy</h3>
                    <p class="text-xs text-slate-400 leading-relaxed mb-6 font-medium">All sensitive information like API keys and PII are encrypted at rest with military-grade standards.</p>
                    <button class="w-full py-3 bg-white/10 hover:bg-white/20 transition-all rounded-xl text-[10px] font-black uppercase tracking-widest backdrop-blur-sm border border-white/5">View Audit Log</button>
                </div>
            </div>
        </div>
    </div>
</div>

