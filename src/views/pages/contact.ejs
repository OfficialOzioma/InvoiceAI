<%- include('../partials/nav') %>

<main class="pt-32 pb-24 px-6 md:px-12 bg-[#F8FAFC]">
    <div class="max-w-3xl mx-auto space-y-12">
        <div class="space-y-4">
            <h1 class="text-4xl md:text-6xl font-black tracking-tighter text-secondary">Contact Us</h1>
            <p class="text-lg text-slate-500 font-medium leading-relaxed">
                We're here to help you accelerate your business.
            </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
            <div class="space-y-8">
                <div class="space-y-2">
                    <h3 class="text-[10px] font-bold uppercase tracking-widest text-primary">Support</h3>
                    <p class="text-slate-600 font-medium">support@invoiceai.com</p>
                </div>
                <div class="space-y-2">
                    <h3 class="text-[10px] font-bold uppercase tracking-widest text-primary">Sales</h3>
                    <p class="text-slate-600 font-medium">sales@invoiceai.com</p>
                </div>
                <div class="space-y-2">
                    <h3 class="text-[10px] font-bold uppercase tracking-widest text-primary">Office</h3>
                    <p class="text-slate-600 font-medium">123 Innovation Drive,<br/>Silicon Valley, CA 94025</p>
                </div>
            </div>

            <form action="#" class="bg-white p-8 rounded-3xl border border-slate-200 shadow-sm space-y-6">
                <div class="space-y-2">
                    <label class="text-[10px] font-bold uppercase tracking-widest text-muted">Name</label>
                    <input type="text" placeholder="Jane Doe" class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-3 text-sm outline-none focus:border-primary transition-all">
                </div>
                <div class="space-y-2">
                    <label class="text-[10px] font-bold uppercase tracking-widest text-muted">Email</label>
                    <input type="email" placeholder="jane@example.com" class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-3 text-sm outline-none focus:border-primary transition-all">
                </div>
                <div class="space-y-2">
                    <label class="text-[10px] font-bold uppercase tracking-widest text-muted">Message</label>
                    <textarea rows="4" placeholder="How can we help?" class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-3 text-sm outline-none focus:border-primary transition-all"></textarea>
                </div>
                <button type="submit" class="w-full bg-primary text-white py-4 rounded-xl font-bold text-xs uppercase tracking-widest hover:bg-secondary transition-all">Send Message</button>
            </form>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
