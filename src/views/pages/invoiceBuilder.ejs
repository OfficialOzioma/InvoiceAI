<div class="space-y-8 pb-20">
  <div class="flex items-center justify-between">
    <a href="/invoices" class="flex items-center gap-2 text-muted hover:text-primary font-bold uppercase text-[10px] tracking-widest transition-colors text-decoration-none">
      <i data-lucide="arrow-left" class="w-4 h-4"></i> Back
    </a>
    <div class="flex gap-4">
      <button 
        id="saveInvoice"
        class="bg-primary text-white px-8 py-3 rounded-md text-xs font-bold shadow-lg shadow-blue-100 hover:bg-secondary transition-all flex items-center gap-2"
      >
        <i data-lucide="save" class="w-4 h-4"></i> Issue Invoice
      </button>
    </div>
  </div>

  <div class="grid lg:grid-cols-3 gap-10">
    <div class="lg:col-span-2 space-y-8">
      <!-- Removed embedded AI block as it's now handled by the separate AI Assistant step -->

    <!-- Builder Form -->
      <div class="bg-white rounded-[16px] border border-border shadow-sm p-10 space-y-10 relative">
        <!-- Template Badge -->
        <div class="absolute top-6 right-10" x-data="{ 
            open: false,
            templateId: '<%= templateId %>',
            templates: [
                { id: 'minimal.html', name: 'Minimal' },
                { id: 'corporate.html', name: 'Corporate' },
                { id: 'modern.html', name: 'Modern' },
                { id: 'bold.html', name: 'Bold' },
                { id: 'standard-plus.html', name: 'Standard Plus' },
                { id: 'timesheet.html', name: 'Timesheet' },
                { id: 'commercial.html', name: 'Commercial' },
                { id: 'milestone.html', name: 'Milestone' },
                { id: 'recurring.html', name: 'Recurring' }
            ],
            changeTemplate(id) {
                this.templateId = id;
            }
        }">
          <button @click="open = !open" 
                  class="text-[9px] font-black uppercase tracking-widest px-3 py-1 bg-slate-100 text-slate-500 rounded-full border border-slate-200 flex items-center gap-1.5 hover:bg-slate-200 transition-all">
            <span x-text="'Style: ' + templateId"></span>
            <i data-lucide="chevron-down" class="w-3 h-3"></i>
          </button>
          <div x-show="open" 
               @click.away="open = false"
               x-transition:enter="transition ease-out duration-100"
               x-transition:enter-start="opacity-0 scale-95"
               x-transition:enter-end="opacity-100 scale-100"
               class="absolute right-0 mt-2 w-48 bg-white rounded-xl shadow-xl border border-slate-100 py-2 z-50">
              <template x-for="tpl in templates" :key="tpl.id">
                  <button @click="changeTemplate(tpl.id); open = false" 
                          class="w-full text-left px-4 py-2 text-[10px] font-bold uppercase tracking-widest hover:bg-slate-50 transition-colors"
                          :class="templateId === tpl.id ? 'text-primary' : 'text-slate-600'"
                          x-text="tpl.name">
                  </button>
              </template>
          </div>
          <input type="hidden" id="selectedTemplateId" :value="templateId">
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <div class="space-y-4">
            <div class="space-y-2">
               <label class="text-[10px] font-bold uppercase tracking-widest text-muted">Invoice Number</label>
               <input 
                id="invoiceNumber"
                type="text" 
                value="INV-<%= Math.floor(Math.random() * 90000) + 10000 %>"
                class="w-full bg-slate-50 border border-border rounded-lg px-4 py-3 text-sm font-bold font-mono outline-none focus:bg-white focus:border-primary transition-all"
               />
            </div>
            <div class="space-y-2">
               <label class="text-[10px] font-bold uppercase tracking-widest text-muted">Client</label>
               <div class="flex gap-2">
                 <select id="clientId" class="flex-1 bg-slate-50 border border-border rounded-lg px-4 py-3 text-sm outline-none focus:bg-white focus:border-primary transition-all">
                    <option value="">Select a Client</option>
                    <option value="new">-- Create New Client --</option>
                    <option value="1">Acme Corp</option>
                 </select>
               </div>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
             <div class="space-y-2">
               <label class="text-[10px] font-bold uppercase tracking-widest text-muted">Issue Date</label>
               <input type="date" value="<%= new Date().toISOString().split('T')[0] %>" class="w-full bg-slate-50 border border-border rounded-lg px-4 py-2 text-xs outline-none" />
            </div>
            <div class="space-y-2">
               <label class="text-[10px] font-bold uppercase tracking-widest text-muted">Due Date</label>
               <% 
                  const dueDate = new Date(); 
                  dueDate.setDate(dueDate.getDate() + 14); 
               %>
               <input type="date" value="<%= dueDate.toISOString().split('T')[0] %>" class="w-full bg-slate-50 border border-border rounded-lg px-4 py-2 text-xs outline-none" />
            </div>
          </div>
        </div>

        <!-- Line Items -->
        <div class="space-y-4">
          <div class="flex items-center justify-between mb-2">
            <label class="text-[10px] font-bold uppercase tracking-widest text-muted">Line Items</label>
            <button id="addItem" class="text-[10px] font-bold uppercase tracking-widest text-primary hover:text-secondary transition-colors flex items-center gap-1">
              <i data-lucide="plus" class="w-3 h-3"></i> Add Item
            </button>
          </div>
          <div id="itemsContainer" class="space-y-3">
            <!-- Dynamic items -->
          </div>
        </div>

        <div class="pt-10 flex justify-end gap-6 items-end mt-4 border-t border-slate-100">
          <div class="w-full flex-1 md:w-auto">
             <button id="saveInvoiceBottom" class="w-full md:w-auto bg-slate-900 text-white px-8 py-3 rounded-xl text-sm font-bold shadow-lg shadow-slate-200 hover:bg-slate-800 transition-all flex items-center justify-center gap-2 mt-4">
              <i data-lucide="check" class="w-4 h-4"></i> Create Invoice
            </button>
          </div>
          <div class="w-72 space-y-4">
            <div class="flex justify-between text-sm text-muted">
              <span>Subtotal</span>
              <span id="subtotalDisplay" class="font-bold font-mono">$0.00</span>
            </div>
            <div class="flex justify-between text-sm text-muted">
              <span>Estimated Tax (10%)</span>
              <span id="taxDisplay" class="font-bold font-mono">$0.00</span>
            </div>
            <div class="pt-4 border-t-2 border-secondary flex justify-between items-center bg-blue-50 px-6 py-4 rounded-xl">
              <span class="font-bold text-secondary">Total Due</span>
              <span id="totalDisplay" class="text-2xl font-extrabold font-mono text-primary tracking-tighter">$0.00</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Preview / Context Sidebar -->
    <div class="space-y-8">
       <div class="bg-white rounded-[16px] border border-border shadow-sm p-8">
        <h3 class="text-[10px] font-bold uppercase tracking-widest text-muted mb-6">Context & Notes</h3>
        <textarea 
          placeholder="Terms, instructions..."
          class="w-full bg-slate-50 border border-border rounded-xl px-4 py-3 text-xs outline-none focus:bg-white focus:border-primary transition-all min-h-[150px]"
        ></textarea>
      </div>
    </div>
  </div>
</div>

<script>
   window.INVOICE_EDIT_DATA = <%- editInvoice ? JSON.stringify(editInvoice) : 'null' %>;
</script>
<script src="/js/builder.js"></script>
