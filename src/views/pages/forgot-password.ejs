<main class="min-h-screen bg-[#F8FAFC] flex flex-col justify-center py-20 px-6 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-md text-center space-y-6 mb-8">
        <a href="/" class="text-3xl font-black tracking-tighter text-secondary inline-flex items-center gap-1">
            Invoice<span class="text-primary italic">AI</span>
        </a>
        <h2 class="text-4xl font-black tracking-tighter text-secondary">Reset password.</h2>
        <p class="text-sm text-slate-500 font-medium">We'll send recovery instructions to your email.</p>
    </div>

    <div class="sm:mx-auto sm:w-full sm:max-w-md">
        <div class="bg-white py-12 px-8 shadow-2xl shadow-blue-500/5 sm:rounded-[40px] border border-slate-100 space-y-8">
            <form action="#" method="POST" class="space-y-6">
                <div class="space-y-2">
                    <label class="text-[10px] font-bold uppercase tracking-widest text-muted">Registered Email</label>
                    <input type="email" name="email" required placeholder="name@company.com" class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-4 text-sm outline-none focus:border-primary transition-all">
                </div>

                <button type="submit" class="w-full bg-primary text-white py-5 rounded-xl font-bold text-xs uppercase tracking-widest hover:bg-secondary transition-all shadow-xl shadow-blue-100">
                    Send Link
                </button>
            </form>

            <div class="text-center pt-2">
                <a href="/login" class="text-[11px] font-bold uppercase tracking-widest text-primary hover:text-secondary transition-colors inline-flex items-center gap-2">
                    <i data-lucide="arrow-left" class="w-3 h-3"></i> Back to Sign In
                </a>
            </div>
        </div>
    </div>
</main>
