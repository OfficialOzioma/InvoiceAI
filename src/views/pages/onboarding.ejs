<%- include('../partials/layout-header') %>

<style>
    .font-serif { font-family: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif; }
    .tracking-widest-extra { tracking: 0.2em; }
    #previewContainer { transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1); }
</style>

<main class="min-h-screen bg-[#F8FAFC] py-12 px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
        <!-- Progress Header -->
        <div class="mb-12">
            <div class="flex items-center justify-between mb-4">
                <a href="/" class="text-2xl font-black tracking-tighter text-secondary">
                    Invoice<span class="text-primary italic">AI</span>
                </a>
                <span class="text-[10px] font-bold uppercase tracking-widest text-muted">Step <%= step %> of <%= totalSteps %></span>
            </div>
            <div class="h-1.5 w-full bg-slate-200 rounded-full overflow-hidden">
                <div class="h-full bg-primary transition-all duration-500" style="width: <%= (step / totalSteps) * 100 %>%"></div>
            </div>
        </div>

        <div class="grid lg:grid-cols-2 gap-12 items-start">
            <!-- Form Side -->
            <div class="bg-white p-8 lg:p-12 rounded-[40px] shadow-2xl shadow-blue-500/5 border border-slate-100 space-y-8">
                <div class="space-y-2">
                    <h2 class="text-3xl font-black tracking-tighter text-secondary"><%= stepTitle %></h2>
                    
                    <% if (error) { %>
                        <div class="bg-red-50 border border-red-100 text-red-600 px-4 py-3 rounded-xl text-xs font-bold mb-4">
                            <%= error %>
                        </div>
                    <% } %>

                    <% if (step === 5) { %>
                        <p class="text-sm text-slate-500 font-medium">Almost there! Create your first draft and then you can continue to your dashboard.</p>
                    <% } else { %>
                        <p class="text-sm text-slate-500 font-medium">Let's get your business ready. All details can be changed later.</p>
                    <% } %>
                </div>

                <form action="/onboarding/step/<%= step %>" method="POST" class="space-y-6" id="onboardingForm" enctype="<%= step === 2 ? 'multipart/form-data' : 'application/x-www-form-urlencoded' %>">
                    <% if (step === 1) { %>
                        <!-- Step 1: Business Information -->
                        <div class="space-y-4">
                            <div class="space-y-2">
                                <label class="text-[10px] font-bold uppercase tracking-widest text-muted">Legal Business Name</label>
                                <input type="text" name="businessName" value="<%= onboardingData.businessName || '' %>" required placeholder="Acme International" class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-4 text-sm outline-none focus:border-primary transition-all">
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <div class="space-y-2">
                                    <label class="text-[10px] font-bold uppercase tracking-widest text-muted">Business Email</label>
                                    <input type="email" name="businessEmail" value="<%= onboardingData.businessEmail || '' %>" required placeholder="billing@acme.com" class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-4 text-sm outline-none focus:border-primary transition-all">
                                </div>
                                <div class="space-y-2">
                                    <label class="text-[10px] font-bold uppercase tracking-widest text-muted">Phone Number</label>
                                    <input type="tel" name="phone" value="<%= onboardingData.phone || '' %>" required placeholder="+1 (555) 000-0000" class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-4 text-sm outline-none focus:border-primary transition-all">
                                </div>
                            </div>
                            <div class="space-y-2">
                                <label class="text-[10px] font-bold uppercase tracking-widest text-muted">Registration Address</label>
                                <textarea name="address" required rows="3" placeholder="123 Business Way, Silicon Valley, CA" class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-4 text-sm outline-none focus:border-primary transition-all"><%= onboardingData.address || '' %></textarea>
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <div class="space-y-2">
                                    <label class="text-[10px] font-bold uppercase tracking-widest text-muted">Default Currency</label>
                                    <select name="currency" class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-4 text-sm outline-none focus:border-primary transition-all appearance-none">
                                        <option value="USD" <%= onboardingData.currency === 'USD' ? 'selected' : '' %>>$ - US Dollar</option>
                                        <option value="EUR" <%= onboardingData.currency === 'EUR' ? 'selected' : '' %>>€ - Euro</option>
                                        <option value="GBP" <%= onboardingData.currency === 'GBP' ? 'selected' : '' %>>£ - British Pound</option>
                                        <option value="NGN" <%= onboardingData.currency === 'NGN' ? 'selected' : '' %>>₦ - Nigerian Naira</option>
                                    </select>
                                </div>
                                <div class="space-y-2">
                                    <label class="text-[10px] font-bold uppercase tracking-widest text-muted">Tax Registration (Optional)</label>
                                    <input type="text" name="taxId" value="<%= onboardingData.taxId || '' %>" placeholder="VAT-123456" class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-4 text-sm outline-none focus:border-primary transition-all">
                                </div>
                            </div>
                        </div>
                    <% } else if (step === 2) { %>
                        <!-- Step 2: Branding -->
                        <div class="space-y-6">
                            <div class="space-y-4">
                                <div class="flex items-center justify-between">
                                    <label class="text-[10px] font-bold uppercase tracking-widest text-muted">Business Logo</label>
                                    <div class="flex bg-slate-100 p-1 rounded-lg">
                                        <button type="button" onclick="toggleLogoMode('upload')" id="toggleUpload" class="px-3 py-1 rounded-md text-[9px] font-black uppercase tracking-widest transition-all bg-white shadow-sm text-primary">Upload</button>
                                        <button type="button" onclick="toggleLogoMode('url')" id="toggleUrl" class="px-3 py-1 rounded-md text-[9px] font-black uppercase tracking-widest transition-all text-slate-500">URL</button>
                                    </div>
                                </div>
                                <div class="flex flex-col gap-4">
                                    <div class="flex items-center gap-6" id="logoUploadSection">
                                        <div class="w-24 h-24 bg-slate-50 border-2 border-dashed border-slate-200 rounded-2xl flex items-center justify-center text-slate-400 overflow-hidden" id="logoPreview">
                                            <% if (onboardingData.logoUrl) { %>
                                                <img src="<%= onboardingData.logoUrl %>" class="w-full h-full object-contain p-2">
                                            <% } else { %>
                                                <i data-lucide="image" class="w-8 h-8"></i>
                                            <% } %>
                                        </div>
                                        <div class="flex-1 space-y-2">
                                            <input type="file" name="logo" id="logoInput" class="hidden" accept="image/*">
                                            <button type="button" onclick="document.getElementById('logoInput').click()" class="bg-slate-100 text-secondary px-6 py-3 rounded-xl font-bold text-xs uppercase tracking-widest hover:bg-slate-200 transition-all w-full">Upload Logo</button>
                                    <div id="removeLogo" class="<%= onboardingData.logoUrl ? 'flex' : 'hidden' %> items-center justify-center gap-2 text-[10px] font-bold text-red-500 cursor-pointer hover:text-red-600" onclick="clearLogoSelections()">
                                        <i data-lucide="x" class="w-3 h-3"></i> Remove
                                    </div>
                                        </div>
                                    </div>


                                    <div class="relative hidden items-center gap-3" id="logoUrlSection">
                                        <div class="flex-1 relative">
                                            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                                <i data-lucide="link" class="w-4 h-4 text-slate-400"></i>
                                            </div>
                                            <input type="url" name="logoUrl" id="logoUrlInput" value="<%= onboardingData.logoUrl && !onboardingData.logoUrl.startsWith('data:') ? onboardingData.logoUrl : '' %>" placeholder="Paste logo URL (https://...)" class="w-full bg-slate-50 border border-slate-100 rounded-xl pl-11 pr-4 py-4 text-sm outline-none focus:border-primary transition-all">
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="space-y-4">
                                <label class="text-[10px] font-bold uppercase tracking-widest text-muted">Brand Colors</label>
                                <div class="grid grid-cols-2 gap-4">
                                    <div class="relative">
                                        <input type="color" name="colorPrimary" value="<%= onboardingData.colorPrimary || '#3B82F6' %>" class="absolute inset-0 opacity-0 cursor-pointer w-full h-full">
                                        <div class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-4 text-sm flex items-center gap-3">
                                            <div id="colorPrimaryDisplay" class="w-5 h-5 rounded-full border border-slate-200" style="background-color: <%= onboardingData.colorPrimary || '#3B82F6' %>"></div>
                                            <span class="font-bold text-xs uppercase">Primary</span>
                                        </div>
                                    </div>
                                    <div class="relative">
                                        <input type="color" name="colorSecondary" value="<%= onboardingData.colorSecondary || '#0F172A' %>" class="absolute inset-0 opacity-0 cursor-pointer w-full h-full">
                                        <div class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-4 text-sm flex items-center gap-3">
                                            <div id="colorSecondaryDisplay" class="w-5 h-5 rounded-full border border-slate-200" style="background-color: <%= onboardingData.colorSecondary || '#0F172A' %>"></div>
                                            <span class="font-bold text-xs uppercase">Secondary</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% } else if (step === 3) { %>
                        <!-- Step 3: Template Selection -->
                        <div class="grid grid-cols-2 gap-4">
                            <label class="relative cursor-pointer group">
                                <input type="radio" name="templateId" value="modern" <%= (onboardingData.templateId || 'modern') === 'modern' ? 'checked' : '' %> class="absolute opacity-0">
                                <div class="border-2 border-slate-100 rounded-2xl p-4 transition-all group-has-[:checked]:border-primary group-has-[:checked]:bg-blue-50/50">
                                    <div class="aspect-[3/4] bg-slate-100 rounded-lg mb-3 flex items-center justify-center">
                                        <div class="w-12 h-16 bg-white shadow-sm rounded border border-slate-200 rotate-1 flex flex-col p-2 space-y-1">
                                            <div class="h-1 w-full bg-slate-100 rounded"></div>
                                            <div class="h-1 w-2/3 bg-slate-100 rounded"></div>
                                        </div>
                                    </div>
                                    <span class="text-[10px] font-black uppercase tracking-widest">The Modernist</span>
                                </div>
                            </label>
                            <label class="relative cursor-pointer group">
                                <input type="radio" name="templateId" value="royal" <%= onboardingData.templateId === 'royal' ? 'checked' : '' %> class="absolute opacity-0">
                                <div class="border-2 border-slate-100 rounded-2xl p-4 transition-all group-has-[:checked]:border-primary group-has-[:checked]:bg-blue-50/50">
                                    <div class="aspect-[3/4] bg-slate-100 rounded-lg mb-3 flex items-center justify-center">
                                        <div class="w-12 h-16 bg-white shadow-sm rounded border border-slate-200 flex flex-col items-center p-2 space-y-2">
                                            <div class="w-3 h-3 rounded-full bg-slate-200"></div>
                                            <div class="h-0.5 w-full bg-slate-100 rounded"></div>
                                            <div class="h-0.5 w-1/2 bg-slate-100 rounded"></div>
                                            <div class="h-px w-full bg-slate-800 my-1"></div>
                                        </div>
                                    </div>
                                    <span class="text-[10px] font-black uppercase tracking-widest">Royal Serif</span>
                                </div>
                            </label>
                        </div>
                    <% } else if (step === 4) { %>
                        <!-- Step 4: Payment Configuration -->
                        <div class="space-y-6">
                            <label class="block p-6 border-2 border-slate-100 rounded-[24px] cursor-pointer transition-all has-[:checked]:border-primary has-[:checked]:bg-blue-50/50">
                                <input type="radio" name="paymentType" value="platform" checked class="hidden peer">
                                <div class="flex items-start gap-4">
                                    <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center shrink-0">
                                        <i data-lucide="zap" class="w-5 h-5 text-primary"></i>
                                    </div>
                                    <div>
                                        <span class="block text-sm font-black text-secondary">Platform Gateway (Recommended)</span>
                                        <span class="block text-xs text-slate-500 mt-1">Zero setup. We handle everything for a small transaction fee.</span>
                                    </div>
                                </div>
                            </label>

                            <label class="block p-6 border-2 border-slate-100 rounded-[24px] cursor-pointer transition-all has-[:checked]:border-primary has-[:checked]:bg-blue-50/50 group">
                                <input type="radio" name="paymentType" value="custom" class="hidden peer">
                                <div class="flex items-start gap-4">
                                    <div class="w-10 h-10 bg-slate-100 rounded-xl flex items-center justify-center shrink-0 group-has-[:checked]:bg-primary/10">
                                        <i data-lucide="shield-check" class="w-5 h-5 text-slate-400 group-has-[:checked]:text-primary"></i>
                                    </div>
                                    <div class="flex-1">
                                        <span class="block text-sm font-black text-secondary">Direct Paystack Connect</span>
                                        <span class="block text-xs text-slate-500 mt-1">Full control. Connect your own Paystack keys.</span>
                                        
                                        <div class="mt-4 space-y-3 hidden group-has-[:checked]:block">
                                            <input type="text" name="paystackPublicKey" placeholder="pk_test_..." class="w-full bg-white border border-slate-100 rounded-lg px-4 py-3 text-xs outline-none focus:border-primary">
                                            <input type="password" name="paystackSecretKey" placeholder="sk_test_..." class="w-full bg-white border border-slate-100 rounded-lg px-4 py-3 text-xs outline-none focus:border-primary">
                                        </div>
                                    </div>
                                </div>
                            </label>
                        </div>
                    <% } else if (step === 5) { %>
                        <!-- Step 5: First Invoice Training -->
                        <div class="space-y-6">
                            <div class="flex p-1 bg-slate-100 rounded-xl">
                                <button type="button" onclick="toggleInvoiceMode('manual')" class="flex-1 py-3 text-[10px] font-black uppercase tracking-widest rounded-lg transition-all" id="btnManual">Manual Entry</button>
                                <button type="button" onclick="toggleInvoiceMode('ai')" class="flex-1 py-3 text-[10px] font-black uppercase tracking-widest rounded-lg bg-white shadow-sm ring-1 ring-slate-200 transition-all" id="btnAI">AI Assistant</button>
                            </div>

                            <div id="manualFields" class="hidden space-y-4">
                                <div class="grid grid-cols-2 gap-4">
                                    <div class="space-y-2">
                                        <label class="text-[10px] font-bold uppercase tracking-widest text-muted">Client Name</label>
                                        <input type="text" name="clientName" id="clientName" placeholder="John Doe" class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-4 text-sm outline-none focus:border-primary transition-all">
                                    </div>
                                    <div class="space-y-2">
                                        <label class="text-[10px] font-bold uppercase tracking-widest text-muted">Client Address</label>
                                        <input type="text" name="clientAddress" id="clientAddress" placeholder="456 Avenue, NY" class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-4 text-sm outline-none focus:border-primary transition-all">
                                    </div>
                                </div>
                                <div class="space-y-2">
                                    <label class="text-[10px] font-bold uppercase tracking-widest text-muted">Line Items (2 - 4 items)</label>
                                    <div id="itemsContainer" class="space-y-2">
                                        <% for(let i = 0; i < 2; i++) { %>
                                            <div class="flex gap-2">
                                                <input type="text" name="items[<%= i %>][description]" placeholder="Item name" class="flex-1 bg-slate-50 border border-slate-100 rounded-lg px-3 py-3 text-xs">
                                                <input type="number" name="items[<%= i %>][amount]" placeholder="Price" class="w-24 bg-slate-50 border border-slate-100 rounded-lg px-3 py-3 text-xs">
                                            </div>
                                        <% } %>
                                    </div>
                                    <button type="button" id="addItemBtn" onclick="addInvoiceItem()" class="text-[10px] font-bold text-primary flex items-center gap-1 mt-2">
                                        <i data-lucide="plus" class="w-3 h-3"></i> Add More Items
                                    </button>
                                </div>
                            </div>

                            <div id="aiMode" class="space-y-4">
                                <div class="space-y-2">
                                    <label class="text-[10px] font-bold uppercase tracking-widest text-muted">What are you billing for?</label>
                                    <textarea name="aiPrompt" id="aiPrompt" rows="4" placeholder="I just completed 10 hours of web development for a New York client at $150/hr..." class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-4 text-sm outline-none focus:border-primary transition-all"></textarea>
                                </div>
                                <button type="button" onclick="generateAIInvoice()" id="generateBtn" class="w-full border-2 border-primary text-primary py-4 rounded-xl font-bold text-xs uppercase tracking-widest hover:bg-primary hover:text-white transition-all flex items-center justify-center gap-2">
                                    <i data-lucide="sparkles" class="w-4 h-4"></i>
                                    Generate Draft
                                </button>
                            </div>
                        </div>
                    <% } %>

                    <div class="pt-8 space-y-4">
                        <div class="flex items-center gap-4">
                            <% if (step > 1) { %>
                                <a href="/onboarding/step/<%= step - 1 %>" class="flex-1 bg-white border border-slate-200 text-secondary py-5 rounded-xl font-bold text-xs uppercase tracking-widest hover:border-primary transition-all text-center">
                                    Back
                                </a>
                            <% } %>
                            <button type="submit" class="<%= step > 1 ? 'flex-[2]' : 'w-full' %> bg-primary text-white py-5 rounded-xl font-bold text-xs uppercase tracking-widest hover:bg-secondary transition-all shadow-xl shadow-blue-100 flex items-center justify-center gap-3">
                                <%= step === 5 ? 'Launch Dashboard' : 'Continue' %>
                                <i data-lucide="arrow-right" class="w-4 h-4"></i>
                            </button>
                        </div>
                        <div class="text-center">
                            <a href="/onboarding/skip" class="text-[9px] font-black text-slate-400 uppercase tracking-widest hover:text-primary transition-all">Skip for now & setup later</a>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Preview Side -->
            <div class="sticky top-12 hidden lg:block">
                <div class="bg-slate-900 rounded-[40px] p-8 aspect-[3/4] shadow-2xl relative overflow-hidden group">
                    <div class="absolute inset-x-0 top-0 h-1 mt-4 mx-8 bg-slate-800 rounded-full overflow-hidden">
                        <div class="h-full bg-primary/20 w-1/3 animate-pulse"></div>
                    </div>
                    
                    <div class="mt-8 space-y-6">
                        <div id="previewContainer" class="transition-all duration-500">
                            <div class="flex justify-between items-start">
                                <div class="w-20 h-20 bg-slate-800 rounded-2xl flex items-center justify-center overflow-hidden" id="previewLogo">
                                    <% if (onboardingData.logoUrl) { %>
                                        <img src="<%= onboardingData.logoUrl %>" class="w-full h-full object-contain p-2">
                                    <% } else { %>
                                        <i data-lucide="image" class="w-8 h-8 text-slate-700"></i>
                                    <% } %>
                                </div>
                                <div class="space-y-1 text-right max-w-[60%]">
                                    <div id="previewBusinessName" class="text-sm font-black text-white truncate h-5"><%= onboardingData.businessName || 'Company Name' %></div>
                                    <div id="previewPhone" class="text-[8px] text-slate-400 h-3"><%= onboardingData.phone || '' %></div>
                                    <div id="previewAddress" class="text-[10px] text-slate-500 line-clamp-2 h-8"><%= onboardingData.address || 'Street Address, City' %></div>
                                </div>
                            </div>
                            <div class="h-px bg-slate-800 my-6"></div>
                            <div class="space-y-4">
                                <div class="flex justify-between items-center">
                                    <span class="text-[10px] uppercase font-bold text-slate-500">Bill To:</span>
                                    <span id="previewClientName" class="text-[10px] font-bold text-slate-300">Client Name</span>
                                </div>
                                <div id="previewItems" class="space-y-2">
                                    <div id="previewItemsPlaceholder" class="flex justify-between text-[10px] text-slate-400">
                                        <div class="h-3 w-1/2 bg-slate-800 rounded"></div>
                                        <div class="h-3 w-8 bg-slate-800 rounded"></div>
                                    </div>
                                </div>
                            </div>
                            <div class="pt-8 space-y-4">
                                <div class="flex justify-between border-t border-slate-800 pt-4">
                                    <span class="text-[10px] font-bold text-slate-500">Total</span>
                                    <span id="previewTotal" class="text-sm font-black text-white">$0.00</span>
                                </div>
                            </div>
                            <div class="pt-8 flex justify-end">
                                <div id="previewButton" class="h-10 px-6 bg-primary/20 border border-primary/30 rounded-xl flex items-center justify-center">
                                    <span class="text-[10px] font-black uppercase tracking-widest text-primary">Pay Invoice</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-transparent flex items-end p-8">
                        <span class="text-[10px] font-bold uppercase tracking-widest text-slate-500 italic">Live Workspace Preview</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<script type="module">
    import { GoogleGenAI, Type } from "https://esm.run/@google/genai";

    window.toggleLogoMode = function(mode) {
        const upload = document.getElementById('logoUploadSection');
        const url = document.getElementById('logoUrlSection');
        const btnUpload = document.getElementById('toggleUpload');
        const btnUrl = document.getElementById('toggleUrl');
        
        if (mode === 'url') {
            upload.classList.add('hidden');
            url.classList.remove('hidden');
            btnUrl.classList.add('bg-white', 'shadow-sm', 'text-primary');
            btnUrl.classList.remove('text-slate-500');
            btnUpload.classList.remove('bg-white', 'shadow-sm', 'text-primary');
            btnUpload.classList.add('text-slate-500');
        } else {
            upload.classList.remove('hidden');
            url.classList.add('hidden');
            btnUpload.classList.add('bg-white', 'shadow-sm', 'text-primary');
            btnUpload.classList.remove('text-slate-500');
            btnUrl.classList.remove('bg-white', 'shadow-sm', 'text-primary');
            btnUrl.classList.add('text-slate-500');
        }
    }

    window.toggleInvoiceMode = function(mode) {
        const manual = document.getElementById('manualFields');
        const ai = document.getElementById('aiMode');
        const btnManual = document.getElementById('btnManual');
        const btnAI = document.getElementById('btnAI');

        if (mode === 'manual') {
            manual.classList.remove('hidden');
            ai.classList.add('hidden');
            btnManual.classList.add('bg-white', 'shadow-sm', 'ring-1', 'ring-slate-200');
            btnAI.classList.remove('bg-white', 'shadow-sm', 'ring-1', 'ring-slate-200');
        } else {
            manual.classList.add('hidden');
            ai.classList.remove('hidden');
            btnAI.classList.add('bg-white', 'shadow-sm', 'ring-1', 'ring-slate-200');
            btnManual.classList.remove('bg-white', 'shadow-sm', 'ring-1', 'ring-slate-200');
        }
    }

    const GEMINI_API_KEY = "<%= process.env.GEMINI_API_KEY %>";
    const storedData = <%- JSON.stringify(onboardingData) %>;

    // Preview Sync Logic
    const updatePreview = () => {
        const form = document.getElementById('onboardingForm');
        const formData = new FormData(form);
        
        // Merge stored and current data
        const currentData = { ...storedData };
        for (let [key, value] of formData.entries()) {
            if (value) currentData[key] = value;
        }
        
        // Step 1 values
        const businessName = currentData.businessName;
        const address = currentData.address;
        const phone = currentData.phone;
        const currency = currentData.currency || 'USD';
        
        const currencyMap = { 'USD': '$', 'EUR': '€', 'GBP': '£', 'NGN': '₦' };
        const symbol = currencyMap[currency] || '$';

        if (businessName) document.getElementById('previewBusinessName').innerText = businessName;
        if (address) document.getElementById('previewAddress').innerText = address;
        if (phone) document.getElementById('previewPhone').innerText = phone;

        // Step 2 values (Logo & Colors)
        const primaryColor = currentData.colorPrimary || '#3B82F6';
        const secondaryColor = currentData.colorSecondary || '#0F172A';

        const colorDisplay = document.getElementById('colorPrimaryDisplay');
        if (colorDisplay) colorDisplay.style.backgroundColor = primaryColor;
        
        const secondDisplay = document.getElementById('colorSecondaryDisplay');
        if (secondDisplay) secondDisplay.style.backgroundColor = secondaryColor;

        const previewBtn = document.getElementById('previewButton');
        previewBtn.style.borderColor = `${primaryColor}4D`;
        previewBtn.style.backgroundColor = `${primaryColor}1A`;
        previewBtn.querySelector('span').style.color = primaryColor;

        const logoUrl = currentData.logoUrl;
        if (logoUrl) {
            document.getElementById('previewLogo').innerHTML = `<img src="${logoUrl}" class="w-full h-full object-contain p-2">`;
        }

        // Step 3 values (Template)
        const template = currentData.templateId || 'modern';
        const container = document.getElementById('previewContainer');
        const bizName = document.getElementById('previewBusinessName');
        const logo = document.getElementById('previewLogo');
        const divider = document.querySelector('.h-px.bg-slate-800.my-6');

        if (template === 'royal') {
            container.classList.add('flex', 'flex-col', 'items-center', 'text-center', 'pt-20', 'space-y-12');
            logo.classList.add('mx-auto', 'mb-8', 'scale-[1.75]', 'grayscale', 'bg-transparent');
            logo.classList.remove('bg-slate-800');
            
            bizName.classList.remove('truncate', 'text-sm');
            bizName.classList.add('text-4xl', 'font-light', 'uppercase', 'tracking-[0.4em]', 'leading-tight', 'font-serif', 'max-w-[320px]', 'break-words');
            
            if (divider) {
                divider.classList.remove('bg-slate-800');
                divider.classList.add('bg-slate-900', 'w-24', 'mx-auto', 'h-[1px]', 'my-12', 'opacity-30');
            }

            document.getElementById('previewPhone').classList.add('hidden');
            document.getElementById('previewAddress').classList.add('text-[10px]', 'font-medium', 'tracking-[0.2em]', 'uppercase', 'font-serif');
            document.getElementById('previewAddress').classList.remove('text-slate-500');
            document.getElementById('previewAddress').classList.add('text-slate-600');
            
            document.getElementById('previewItemsPlaceholder').classList.add('border-y', 'border-slate-800', 'py-12', 'border-opacity-10');
            document.getElementById('previewItemsPlaceholder').classList.remove('border-b');
        } else {
            container.classList.remove('flex', 'flex-col', 'items-center', 'text-center', 'pt-20', 'space-y-12');
            logo.classList.remove('mx-auto', 'mb-8', 'scale-[1.75]', 'grayscale', 'bg-transparent');
            logo.classList.add('bg-slate-800');
            
            bizName.classList.remove('text-4xl', 'font-light', 'uppercase', 'tracking-[0.4em]', 'leading-tight', 'font-serif', 'max-w-[320px]', 'break-words');
            bizName.classList.add('truncate', 'text-sm');
            
            if (divider) {
                divider.classList.remove('bg-slate-900', 'w-24', 'mx-auto', 'h-[1px]', 'my-12', 'opacity-30');
                divider.classList.add('bg-slate-800', 'h-px', 'my-6');
            }

            document.getElementById('previewPhone').classList.remove('hidden');
            document.getElementById('previewAddress').classList.remove('text-[10px]', 'font-medium', 'tracking-[0.2em]', 'uppercase', 'font-serif', 'text-slate-600');
            document.getElementById('previewAddress').classList.add('text-slate-500');
            document.getElementById('previewItemsPlaceholder').classList.remove('border-y', 'border-slate-800', 'py-12', 'border-opacity-10');
            document.getElementById('previewItemsPlaceholder').classList.add('border-b');
        }

        // Step 5 values
        const clientName = currentData.clientName;
        const clientAddress = currentData.clientAddress;
        if (clientName) {
            document.getElementById('previewClientName').innerHTML = `
                <div class="flex flex-col text-right">
                    <span>${clientName}</span>
                    <span class="text-[8px] opacity-60">${clientAddress || ''}</span>
                </div>
            `;
        }

        // Calculate Items and Total
        let total = 0;
        const itemsPreview = document.getElementById('previewItems');
        const itemRows = document.querySelectorAll('#itemsContainer .flex');
        
        if (itemRows.length > 0) {
            let hasItems = false;
            let itemsHtml = '';
            itemRows.forEach(row => {
                const desc = row.querySelector('input[name*="[description]"]')?.value;
                const amt = parseFloat(row.querySelector('input[name*="[amount]"]')?.value) || 0;
                
                if (desc || amt > 0) {
                    hasItems = true;
                    itemsHtml += `<div class="flex justify-between text-[10px] text-slate-400"><span>${desc || 'Item'}</span><span>${symbol}${amt.toLocaleString()}</span></div>`;
                    total += amt;
                }
            });

            if (hasItems) {
                itemsPreview.innerHTML = itemsHtml;
                document.getElementById('previewTotal').innerText = `${symbol}${total.toLocaleString()}`;
            }
        }
    };

    window.addInvoiceItem = function() {
        const container = document.getElementById('itemsContainer');
        const count = container.querySelectorAll('.flex').length;
        if (count >= 4) {
            alert("Maximum 4 items allowed for initial setup. You can add more later in the dashboard.");
            return;
        }
        
        const idx = count;
        const div = document.createElement('div');
        div.className = 'flex gap-2';
        div.innerHTML = `
            <input type="text" name="items[${idx}][description]" placeholder="Item name" class="flex-1 bg-slate-50 border border-slate-100 rounded-xl px-3 py-3 text-xs outline-none focus:border-primary">
            <input type="number" name="items[${idx}][amount]" placeholder="Price" class="w-24 bg-slate-50 border border-slate-100 rounded-xl px-3 py-3 text-xs outline-none focus:border-primary">
        `;
        container.appendChild(div);
        
        div.querySelectorAll('input').forEach(input => {
            input.addEventListener('input', updatePreview);
        });

        if (count + 1 >= 4) {
            document.getElementById('addItemBtn').style.display = 'none';
        }
    };

    // Attach listeners to all inputs
    document.querySelectorAll('#onboardingForm input, #onboardingForm textarea, #onboardingForm select').forEach(input => {
        input.addEventListener('input', updatePreview);
        input.addEventListener('change', updatePreview);
    });

    // Initialize preview on load
    document.addEventListener('DOMContentLoaded', () => {
        updatePreview();
        if (typeof lucide !== 'undefined') lucide.createIcons();
    });

    window.generateAIInvoice = async function() {
        const prompt = document.getElementById('aiPrompt').value;
        if (!prompt) return alert('Please describe your work first.');

        const btn = document.getElementById('generateBtn');
        btn.disabled = true;
        btn.innerHTML = '<i data-lucide="loader" class="w-4 h-4 animate-spin"></i> Processing...';
        lucide.createIcons();

        try {
            const ai = new GoogleGenAI({ apiKey: GEMINI_API_KEY });
            const response = await ai.models.generateContent({
                model: "gemini-3-flash-preview",
                contents: prompt,
                config: {
                    systemInstruction: "Extract invoice details from the prompt. Return JSON with 'clientName' (string) and 'items' (array of objects with 'description' (string) and 'amount' (number)).",
                    responseMimeType: "application/json",
                    responseSchema: {
                        type: Type.OBJECT,
                        properties: {
                            clientName: { type: Type.STRING },
                            items: {
                                type: Type.ARRAY,
                                items: {
                                    type: Type.OBJECT,
                                    properties: {
                                        description: { type: Type.STRING },
                                        amount: { type: Type.NUMBER }
                                    },
                                    required: ["description", "amount"]
                                }
                            }
                        },
                        required: ["clientName", "items"]
                    }
                }
            });

            const result = JSON.parse(response.text);
            
            // Populate manual fields and show them for review
            document.getElementById('clientName').value = result.clientName;
            const container = document.getElementById('itemsContainer');
            container.innerHTML = '';
            
            result.items.forEach((item, idx) => {
                const div = document.createElement('div');
                div.className = 'flex gap-2';
                div.innerHTML = `
                    <input type="text" name="items[${idx}][description]" value="${item.description}" class="flex-1 bg-slate-50 border border-slate-100 rounded-lg px-3 py-3 text-xs">
                    <input type="number" name="items[${idx}][amount]" value="${item.amount}" class="w-24 bg-slate-50 border border-slate-100 rounded-lg px-3 py-3 text-xs">
                `;
                container.appendChild(div);
            });

            window.toggleInvoiceMode('manual');
            updatePreview();
        } catch (error) {
            console.error('AI Error:', error);
            alert('AI generation failed. Please try manual entry.');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i data-lucide="sparkles" class="w-4 h-4"></i> Generate Draft';
            lucide.createIcons();
        }
    }

    window.clearLogoSelections = function() {
        document.getElementById('logoInput').value = '';
        document.getElementById('logoUrlInput').value = '';
        document.getElementById('logoPreview').innerHTML = '<i data-lucide="image" class="w-8 h-8"></i>';
        document.getElementById('previewLogo').innerHTML = '<i data-lucide="image" class="w-8 h-8 text-slate-700"></i>';
        document.getElementById('removeLogo').classList.add('hidden');
        document.getElementById('logoUrlSection').classList.remove('hidden');
        document.getElementById('logoUploadSection').classList.remove('hidden');
        document.getElementById('logoDivider').classList.remove('hidden');
        lucide.createIcons();
        updatePreview();
    }

    <% if (step === 2) { %>
    document.getElementById('logoInput').addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (file) {
            // Clear URL input
            document.getElementById('logoUrlInput').value = '';
            
            const reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('logoPreview').innerHTML = `<img src="${e.target.result}" class="w-full h-full object-contain p-2">`;
                document.getElementById('previewLogo').innerHTML = `<img src="${e.target.result}" class="w-full h-full object-contain p-2">`;
                document.getElementById('removeLogo').classList.remove('hidden');
            }
            reader.readAsDataURL(file);
        }
    });

    document.getElementById('logoUrlInput').addEventListener('input', function(e) {
        if (e.target.value) {
            // Clear file input
            document.getElementById('logoInput').value = '';
            document.getElementById('removeLogo').classList.remove('hidden');
        } else {
            document.getElementById('removeLogo').classList.add('hidden');
        }
    });

    // Initialize toggle state if URL exists
    if (document.getElementById('logoUrlInput').value) {
        window.toggleLogoMode('url');
    }
    <% } %>
</script>

<%- include('../partials/layout-footer') %>
