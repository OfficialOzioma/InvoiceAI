<div x-data="{ 
    plan: 'Starter',
    billingCycle: 'monthly',
    plans: [
        { 
            name: 'Starter', 
            price: { monthly: 0, annually: 0 }, 
            features: ['10 Invoices/mo', '3 Clients', 'Basic Templates', 'Community Support'],
            current: true,
            color: 'slate'
        },
        { 
            name: 'Pro', 
            price: { monthly: 29, annually: 290 }, 
            features: ['Unlimited Invoices', 'Unlimited Clients', 'AI Insights & Reports', 'Custom Branding', 'Priority Support'],
            current: false,
            color: 'primary'
        },
        { 
            name: 'Scale', 
            price: { monthly: 99, annually: 990 }, 
            features: ['Everything in Pro', 'Team Collaboration (10 seats)', 'API Access', 'Dedicated Account Manager', 'Custom Contracts'],
            current: false,
            color: 'secondary'
        }
    ]
}" class="space-y-6">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
      <div>
        <h1 class="text-2xl font-extrabold tracking-tight mb-1 text-secondary">Subscription</h1>
        <p class="text-sm text-slate-500 font-medium">Manage your plan, billing, and usage limits.</p>
      </div>
      <div class="flex items-center gap-1 bg-slate-100 p-1 rounded-xl w-fit">
          <button @click="billingCycle = 'monthly'" :class="billingCycle === 'monthly' ? 'bg-white text-secondary shadow-sm' : 'text-slate-500'" class="px-4 py-2 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all">Monthly</button>
          <button @click="billingCycle = 'annually'" :class="billingCycle === 'annually' ? 'bg-white text-secondary shadow-sm' : 'text-slate-500'" class="px-4 py-2 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all">Annually <span class="text-teal-500 ml-1">-20%</span></button>
      </div>
    </div>

    <!-- Current Plan Banner -->
    <div class="bg-gradient-to-r from-slate-900 to-indigo-950 rounded-[32px] p-8 text-white relative overflow-hidden shadow-xl shadow-slate-900/20">
        <div class="absolute -right-10 -bottom-10 w-64 h-64 bg-white opacity-[0.03] rounded-full blur-3xl"></div>
        <div class="relative z-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-8">
            <div class="space-y-4">
                <div class="inline-flex items-center gap-2 px-3 py-1 bg-white/10 rounded-full text-[10px] font-black uppercase tracking-widest backdrop-blur-md">
                    Active Plan
                </div>
                <h2 class="text-3xl font-black tracking-tight" x-text="plan + ' Plan'"></h2>
                <p class="text-slate-400 text-sm font-medium">Your next billing date is <span class="text-white font-bold">May 22, 2026</span></p>
            </div>
            <div class="flex gap-4 w-full md:w-auto">
                <button class="flex-1 md:flex-none px-6 py-3 bg-white/10 hover:bg-white/20 transition-all rounded-xl text-[10px] font-black uppercase tracking-widest backdrop-blur-sm border border-white/5">View Invoices</button>
                <button class="flex-1 md:flex-none px-8 py-3 bg-indigo-500 hover:bg-indigo-600 transition-all rounded-xl text-[10px] font-black uppercase tracking-widest shadow-lg shadow-indigo-500/30">Upgrade Now</button>
            </div>
        </div>
    </div>

    <!-- Pricing Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 pt-8">
        <template x-for="p in plans" :key="p.name">
            <div class="bg-white rounded-[32px] border border-slate-100 p-8 flex flex-col items-stretch transition-all relative group"
                 :class="p.current ? 'ring-2 ring-indigo-500 shadow-xl shadow-indigo-500/5' : 'hover:shadow-xl hover:border-indigo-100'">
                
                <template x-if="p.current">
                    <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-indigo-600 text-white px-4 py-1 rounded-full text-[9px] font-black uppercase tracking-widest shadow-lg">Current plan</div>
                </template>

                <div class="mb-8">
                    <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest mb-4" x-text="p.name"></h3>
                    <div class="flex items-baseline gap-1">
                        <span class="text-4xl font-black tracking-tighter text-slate-900" x-text="'$' + p.price[billingCycle]"></span>
                        <span class="text-xs text-slate-400 font-bold uppercase tracking-widest" x-text="billingCycle === 'monthly' ? '/mo' : '/yr'"></span>
                    </div>
                </div>

                <div class="space-y-4 flex-1 mb-10">
                    <template x-for="feature in p.features">
                        <div class="flex items-center gap-3 text-xs font-medium text-slate-600">
                            <div class="w-5 h-5 rounded-full bg-slate-50 flex items-center justify-center text-indigo-500 group-hover:bg-indigo-50 transition-colors">
                                <i data-lucide="check" class="w-3 h-3"></i>
                            </div>
                            <span x-text="feature"></span>
                        </div>
                    </template>
                </div>

                <button :disabled="p.current"
                        class="w-full py-4 rounded-2xl text-[10px] font-black uppercase tracking-widest transition-all"
                        :class="p.name === 'Scale' ? 'bg-slate-900 text-white hover:bg-slate-800' : 
                                p.name === 'Pro' ? 'bg-primary text-white hover:bg-secondary shadow-lg shadow-blue-500/20' : 
                                'bg-slate-50 text-slate-400'">
                    <span x-text="p.current ? 'Active' : 'Choose ' + p.name"></span>
                </button>
            </div>
        </template>
    </div>

    <!-- Usage Metrics -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 pt-8">
        <div class="bg-white rounded-3xl border border-slate-100 p-8 shadow-sm">
            <h4 class="text-xs font-black text-slate-900 uppercase tracking-widest mb-6">Invoice Usage</h4>
            <div class="space-y-6">
                <div class="flex justify-between items-end">
                    <div class="text-sm font-black text-slate-900 tracking-tight">5 <span class="text-slate-400 font-medium">/ 10 Invoices</span></div>
                    <div class="text-[10px] font-bold text-indigo-600 uppercase tracking-widest">50% used</div>
                </div>
                <div class="w-full h-2 bg-slate-100 rounded-full overflow-hidden">
                    <div class="h-full bg-indigo-500 rounded-full" style="width: 50%"></div>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-3xl border border-slate-100 p-8 shadow-sm">
            <h4 class="text-xs font-black text-slate-900 uppercase tracking-widest mb-6">Client Connections</h4>
            <div class="space-y-6">
                <div class="flex justify-between items-end">
                    <div class="text-sm font-black text-slate-900 tracking-tight">3 <span class="text-slate-400 font-medium">/ 3 Clients</span></div>
                    <div class="text-[10px] font-bold text-rose-600 uppercase tracking-widest">Limit Reached</div>
                </div>
                <div class="w-full h-2 bg-slate-100 rounded-full overflow-hidden">
                    <div class="h-full bg-rose-500 rounded-full" style="width: 100%"></div>
                </div>
                <p class="text-[10px] text-slate-400 font-medium">You need to upgrade to add more clients.</p>
            </div>
        </div>
    </div>
</div>
