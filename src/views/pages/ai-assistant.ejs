<div x-data="aiAssistantData()" class="max-w-4xl mx-auto h-[calc(100vh-12rem)] flex flex-col bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
    <!-- Header -->
    <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50 flex items-center justify-between">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-primary text-white rounded-xl flex items-center justify-center shadow-lg shadow-blue-500/20">
                <i data-lucide="sparkles" class="w-5 h-5"></i>
            </div>
            <div>
                <h1 class="text-sm font-black text-slate-900 tracking-tight">AI Billing Assistant</h1>
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Powered by Gemini</p>
            </div>
        </div>
        <div class="flex items-center gap-2">
            <div class="relative" x-data="{ open: false }">
                <button @click="open = !open" 
                        class="text-[10px] font-bold px-3 py-1.5 bg-blue-50 text-primary rounded-full uppercase tracking-widest flex items-center gap-1.5 hover:bg-blue-100 transition-all border border-blue-100/50">
                    <span x-text="'Template: ' + templateId"></span>
                    <i data-lucide="chevron-down" class="w-3 h-3"></i>
                </button>
                <div x-show="open" 
                     @click.away="open = false"
                     x-transition:enter="transition ease-out duration-100"
                     x-transition:enter-start="opacity-0 scale-95"
                     x-transition:enter-end="opacity-100 scale-100"
                     class="absolute right-0 mt-2 w-48 bg-white rounded-xl shadow-xl border border-slate-100 py-2 z-50">
                    <template x-for="tpl in templates" :key="tpl.id">
                        <button @click="templateId = tpl.id; open = false" 
                                class="w-full text-left px-4 py-2 text-[10px] font-bold uppercase tracking-widest hover:bg-slate-50 transition-colors"
                                :class="templateId === tpl.id ? 'text-primary' : 'text-slate-600'"
                                x-text="tpl.name">
                        </button>
                    </template>
                </div>
            </div>
            <a href="/invoices/wizard" class="w-8 h-8 flex items-center justify-center text-slate-400 hover:text-slate-900 bg-slate-100 rounded-lg transition-all">
                <i data-lucide="x" class="w-4 h-4"></i>
            </a>
        </div>
    </div>

    <!-- Chat Area -->
    <div class="flex-1 overflow-y-auto p-6 space-y-6" id="chatContainer">
        <!-- AI Welcome Message -->
        <div class="flex gap-4 max-w-[85%]">
            <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center shrink-0">
                <i data-lucide="bot" class="w-4 h-4 text-slate-600"></i>
            </div>
            <div class="bg-slate-50 p-4 rounded-2xl rounded-tl-none border border-slate-100">
                <p class="text-sm text-slate-700 leading-relaxed">
                    Hello! I'm your billing assistant. Tell me what you're invoicing for today. For example: 
                    <span class="italic font-medium">"I did 10 hours of web design at $150/hr for Acme Corp."</span>
                </p>
            </div>
        </div>

        <!-- Dynamic Messages -->
        <template x-for="msg in messages" :key="msg.id">
            <div :class="msg.role === 'user' ? 'flex flex-row-reverse gap-4 ml-auto max-w-[85%]' : 'flex gap-4 max-w-[85%]'">
                <div :class="msg.role === 'user' ? 'bg-primary text-white p-4 rounded-2xl rounded-tr-none shadow-md shadow-blue-500/10' : 'bg-slate-50 p-4 rounded-2xl rounded-tl-none border border-slate-100'">
                    <p class="text-sm leading-relaxed" x-text="msg.content"></p>
                </div>
            </div>
        </template>

        <!-- Loading State -->
        <div x-show="loading" class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center shrink-0">
                <i data-lucide="bot" class="w-4 h-4 text-slate-600 animate-bounce"></i>
            </div>
            <div class="bg-slate-50 p-4 rounded-2xl rounded-tl-none border border-slate-100 flex items-center gap-2">
                <div class="flex gap-1">
                    <div class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce [animation-delay:-0.3s]"></div>
                    <div class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce [animation-delay:-0.15s]"></div>
                    <div class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce"></div>
                </div>
                <span class="text-xs font-bold text-slate-400 uppercase tracking-widest">Assistant is thinking...</span>
            </div>
        </div>
    </div>

    <!-- Input Area -->
    <div class="p-6 border-t border-slate-100 bg-white">
        <form @submit.prevent="sendMessage" class="relative">
            <textarea 
                x-model="userInput" 
                @keydown.enter.prevent="if(!loading) sendMessage()"
                class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-5 py-4 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all resize-none pr-14"
                placeholder="Describe your items, rates, and client..."
                rows="2"></textarea>
            <button 
                type="submit"
                :disabled="loading || !userInput.trim()"
                class="absolute right-3 bottom-3 w-10 h-10 bg-primary text-white rounded-xl flex items-center justify-center shadow-lg shadow-blue-500/20 hover:bg-secondary transition-all disabled:opacity-50">
                <i data-lucide="send" class="w-4 h-4"></i>
            </button>
        </form>
    </div>

    <!-- Result / Preview Modal -->
    <div x-show="draft" 
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 scale-95"
         class="fixed inset-0 z-[100] flex items-center justify-center p-6 bg-slate-900/40 backdrop-blur-sm">
        <div class="bg-white rounded-3xl w-full max-w-2xl shadow-2xl overflow-hidden flex flex-col max-h-[90vh]">
            <div class="p-6 border-b border-slate-100 flex items-center justify-between">
                <h3 class="text-lg font-black text-slate-900 tracking-tight">AI Generated Draft</h3>
                <button @click="draft = null" class="text-slate-400 hover:text-slate-900 transition-colors">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
            
            <div class="flex-1 overflow-y-auto p-8 bg-slate-50">
                <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100">
                    <div class="flex justify-between mb-8">
                        <div>
                            <div class="text-[10px] font-bold uppercase tracking-widest text-slate-400">Bill To</div>
                            <div class="font-bold text-slate-900" x-text="draft?.clientName || 'Unspecified Client'"></div>
                        </div>
                        <div class="text-right">
                            <div class="text-[10px] font-bold uppercase tracking-widest text-slate-400">Invoice No.</div>
                            <div class="font-bold text-slate-900" x-text="draft?.invoiceNumber"></div>
                        </div>
                    </div>

                    <table class="w-full text-left mb-8">
                        <thead class="text-[10px] font-bold uppercase tracking-widest text-slate-400 border-b border-slate-100">
                            <tr>
                                <th class="pb-3">Item</th>
                                <th class="pb-3 text-right">Qty</th>
                                <th class="pb-3 text-right">Rate</th>
                                <th class="pb-3 text-right">Total</th>
                            </tr>
                        </thead>
                        <tbody class="text-sm divide-y divide-slate-50">
                            <template x-for="item in draft?.items" :key="item.description">
                                <tr>
                                    <td class="py-4 text-slate-700 font-medium" x-text="item.description"></td>
                                    <td class="py-4 text-right text-slate-500" x-text="item.quantity"></td>
                                    <td class="py-4 text-right text-slate-500" x-text="'$' + item.unitPrice"></td>
                                    <td class="py-4 text-right text-slate-900 font-bold" x-text="'$' + item.total"></td>
                                </tr>
                            </template>
                        </tbody>
                    </table>

                    <div class="flex justify-end pt-6 border-t border-slate-100">
                        <div class="text-right">
                            <div class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Total Amount</div>
                            <div class="text-3xl font-black text-slate-900 tracking-tighter" x-text="'$' + draft?.total"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="p-6 bg-white border-t border-slate-100 flex gap-4">
                <button @click="draft = null" class="flex-1 px-6 py-3 rounded-2xl bg-slate-100 text-slate-600 font-bold text-sm tracking-tight hover:bg-slate-200 transition-all">
                    Discard and Retry
                </button>
                <button @click="confirmDraft" class="flex-1 px-6 py-3 rounded-2xl bg-primary text-white font-bold text-sm tracking-tight hover:bg-secondary transition-all shadow-lg shadow-blue-500/20">
                    Use this Draft
                </button>
            </div>
        </div>
    </div>
</div>

<script>
console.log("AI Assistant Script Loaded (Standard Tag)");

window.aiAssistantData = function() {
    return {
        messages: [],
        userInput: '',
        loading: false,
        draft: null,
        templateId: '<%= templateId %>',
        templates: [
            { id: 'minimal.html', name: 'Minimal' },
            { id: 'corporate.html', name: 'Corporate' },
            { id: 'modern.html', name: 'Modern' },
            { id: 'bold.html', name: 'Bold' },
            { id: 'standard-plus.html', name: 'Standard Plus' },
            { id: 'timesheet.html', name: 'Timesheet' },
            { id: 'commercial.html', name: 'Commercial' },
            { id: 'milestone.html', name: 'Milestone' },
            { id: 'recurring.html', name: 'Recurring' }
        ],

        init() {
            console.log("AI Assistant Alpine Component Initialized");
            this.$nextTick(() => {
                if (window.lucide) lucide.createIcons();
            });
        },
        
        async sendMessage() {
            if (!this.userInput || !this.userInput.trim() || this.loading) return;
            
            const userText = this.userInput.trim();
            this.messages.push({ id: Date.now(), role: 'user', content: userText });
            this.userInput = '';
            this.loading = true;
            
            this.$nextTick(() => {
                const container = document.getElementById('chatContainer');
                if (container) container.scrollTop = container.scrollHeight;
                if (window.lucide) lucide.createIcons();
            });

            try {
                const controller = new AbortController();
                const timeoutId = setTimeout(() => controller.abort(), 35000);

                const response = await fetch('/invoices/ai-draft', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ prompt: userText }),
                    signal: controller.signal
                });

                const result = await response.json();
                clearTimeout(timeoutId);
                
                if (!response.ok) {
                    throw new Error(result.error || result.details || 'Server error');
                }

                this.draft = result;
                
                this.messages.push({ 
                    id: Date.now() + 1, 
                    role: 'assistant', 
                    content: "Great! I've extracted the details and opened the preview overlay. Check it out!" 
                });

            } catch (error) {
                console.error("AI Error:", error);
                let msg = "I hit a snag: " + (error.message || "Unknown error");
                if (error.name === 'AbortError') msg = "Request timed out. Please try a simpler request.";
                
                this.messages.push({ 
                    id: Date.now() + 1, 
                    role: 'assistant', 
                    content: msg 
                });
            }
            
            // Set loading to false BEFORE nextTick to ensure Alpine applies it
            this.loading = false;
            
            this.$nextTick(() => {
                try {
                    const container = document.getElementById('chatContainer');
                    if (container) container.scrollTop = container.scrollHeight;
                    if (window.lucide) lucide.createIcons();
                } catch (e) {
                    console.error("Layout error:", e);
                }
            });
        },

        confirmDraft() {
            const jsonString = JSON.stringify(this.draft);
            const serialized = btoa(unescape(encodeURIComponent(jsonString)));
            window.location.href = `/invoices/new?template=${this.templateId}&draft=${serialized}`;
        }
    };
};
</script>
