<div x-data="{ 
    user: {
        firstName: 'John',
        lastName: 'Doe',
        email: '<%= user ? user.email : 'admin@invoiceai.com' %>',
        bio: 'Financial Consultant & Content Creator',
        avatar: null
    },
    save() {
        alert('Profile updated successfully!');
    },
    handleAvatar(e) {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = (f) => this.user.avatar = f.target.result;
            reader.readAsDataURL(file);
        }
    }
}" class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-extrabold tracking-tight mb-1 text-secondary">My Profile</h1>
        <p class="text-sm text-slate-500 font-medium">Manage your personal information and security.</p>
      </div>
      <button @click="save" class="bg-primary text-white px-8 py-2.5 rounded-xl text-xs font-bold hover:bg-secondary transition-all shadow-lg shadow-blue-500/20">
        Update Profile
      </button>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 space-y-8">
            <!-- Account Details -->
            <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
                <div class="p-8 border-b border-slate-50 h-32 bg-slate-900 relative">
                    <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 24px 24px;"></div>
                </div>
                <div class="px-8 pb-8 -mt-16 relative z-10">
                    <div class="flex flex-col md:flex-row gap-6 items-end mb-8">
                        <div class="relative group">
                            <div class="w-32 h-32 rounded-3xl bg-white border-4 border-white shadow-xl flex items-center justify-center overflow-hidden">
                                <template x-if="!user.avatar">
                                    <div class="w-full h-full bg-slate-100 flex items-center justify-center text-slate-300">
                                        <i data-lucide="user" class="w-12 h-12"></i>
                                    </div>
                                </template>
                                <template x-if="user.avatar">
                                    <img :src="user.avatar" class="w-full h-full object-cover">
                                </template>
                            </div>
                            <input type="file" @change="handleAvatar" class="absolute inset-0 opacity-0 cursor-pointer">
                            <div class="absolute -bottom-2 -right-2 w-8 h-8 bg-primary text-white rounded-xl flex items-center justify-center shadow-lg pointer-events-none group-hover:scale-110 transition-transform">
                                <i data-lucide="camera" class="w-4 h-4"></i>
                            </div>
                        </div>
                        <div class="flex-1 pb-2">
                            <h3 class="text-xl font-black text-slate-900 tracking-tight" x-text="user.firstName + ' ' + user.lastName"></h3>
                            <p class="text-xs text-slate-400 font-bold uppercase tracking-widest" x-text="user.email"></p>
                        </div>
                    </div>

                    <div class="grid md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                             <label class="text-[10px] font-bold uppercase tracking-widest text-slate-400">First Name</label>
                             <input type="text" x-model="user.firstName" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl text-sm focus:bg-white focus:border-primary transition-all outline-none">
                        </div>
                        <div class="space-y-2">
                             <label class="text-[10px] font-bold uppercase tracking-widest text-slate-400">Last Name</label>
                             <input type="text" x-model="user.lastName" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl text-sm focus:bg-white focus:border-primary transition-all outline-none">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Professional Info -->
            <div class="bg-white rounded-3xl border border-slate-100 shadow-sm p-8 space-y-6">
                <div class="space-y-2">
                     <label class="text-[10px] font-bold uppercase tracking-widest text-slate-400">Short Bio</label>
                     <textarea x-model="user.bio" rows="3" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl text-sm focus:bg-white focus:border-primary transition-all outline-none resize-none"></textarea>
                     <p class="text-[10px] text-slate-400 font-medium">Brief description for your client communication.</p>
                </div>
            </div>
        </div>

        <div class="space-y-6">
            <!-- Stats -->
            <div class="bg-blue-600 rounded-[32px] p-8 text-white shadow-xl shadow-blue-500/20">
                <div class="flex items-center justify-between mb-8">
                    <span class="text-[10px] font-black uppercase tracking-widest bg-white/20 px-3 py-1 rounded-full">Pro Member</span>
                    <i data-lucide="zap" class="w-5 h-5"></i>
                </div>
                <div class="space-y-1 mb-8">
                    <p class="text-3xl font-black tracking-tight">$458.1k</p>
                    <p class="text-xs text-blue-100 font-medium">Lifetime Invoiced</p>
                </div>
                <button class="w-full py-3 bg-white text-blue-600 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-slate-50 transition-all">Go to Ledger</button>
            </div>

            <form action="/auth/logout" method="POST" class="block">
                <button class="w-full flex items-center justify-center gap-2 px-6 py-4 rounded-3xl text-sm font-bold text-rose-600 bg-rose-50 hover:bg-rose-100 transition-all border border-rose-100">
                    <i data-lucide="log-out" class="w-4 h-4"></i> Log Out
                </button>
            </form>
        </div>
    </div>
</div>
