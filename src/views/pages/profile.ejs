<div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-extrabold tracking-tight mb-1 text-secondary">Profile</h1>
        <p class="text-sm text-slate-500 font-medium">Manage your personal account settings.</p>
      </div>
    </div>
    
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm shadow-slate-200/50 p-12 text-center">
        <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center mx-auto text-slate-400 mb-4 ring-4 ring-slate-100">
            <i data-lucide="user" class="w-8 h-8"></i>
        </div>
        <h3 class="font-bold text-sm text-secondary tracking-tight mb-2"><%= user ? user.email : 'Current User' %></h3>
        <p class="text-[10px] uppercase font-bold text-slate-400 tracking-widest mb-6 border border-slate-200 bg-slate-50 px-3 py-1 rounded inline-block">Free Plan</p>
        
        <form action="/auth/logout" method="POST" class="max-w-[200px] mx-auto">
            <button class="w-full flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl text-xs font-bold text-red-600 bg-red-50 hover:bg-red-100 transition-all border border-red-100">
                <i data-lucide="log-out" class="w-4 h-4"></i> Log Out
            </button>
        </form>
    </div>
</div>
