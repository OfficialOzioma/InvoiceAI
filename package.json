{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npx @tailwindcss/cli -i ./src/styles.css -o ./public/css/output.css --watch\" \"tsx server.ts\"",
    "build": "npx @tailwindcss/cli -i ./src/styles.css -o ./public/css/output.css --minify",
    "start": "node server.ts",
    "clean": "rm -rf public/css/output.css",
    "lint": "tsc --noEmit",
    "migrate": "tsx ./node_modules/knex/bin/cli.js migrate:latest",
    "migrate:make": "tsx ./node_modules/knex/bin/cli.js migrate:make",
    "migrate:rollback": "tsx ./node_modules/knex/bin/cli.js migrate:rollback"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@types/bcrypt": "^6.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "ejs": "^5.0.2",
    "express": "^4.21.2",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "knex": "^3.2.9",
    "openai": "^6.34.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.20.0",
    "sutando": "^1.7.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^4.17.21",
    "@types/express-ejs-layouts": "^2.5.4",
    "@types/express-session": "^1.19.0",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
