{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npx @tailwindcss/cli -i ./src/styles.css -o ./public/css/output.css --watch\" \"nodemon --exec tsx server.ts\"",
    "build": "npx @tailwindcss/cli -i ./src/styles.css -o ./public/css/output.css --minify",
    "start": "node server.ts",
    "clean": "rm -rf public/css/output.css",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "ejs": "^5.0.2",
    "express": "^4.21.2",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.19.0",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "nodemon": "^3.1.14",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^4.17.21",
    "@types/express-ejs-layouts": "^2.5.4",
    "@types/express-session": "^1.19.0",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
