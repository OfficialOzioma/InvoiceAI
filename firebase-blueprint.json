{
  "entities": {
    "User": {
      "title": "User",
      "description": "User account and onboarding state",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "onboardingStatus": { "type": "string", "enum": ["in-progress", "completed"] },
        "currentOnboardingStep": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "onboardingStatus", "currentOnboardingStep"]
    },
    "Business": {
      "title": "Business",
      "description": "Business profile and branding settings",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "currency": { "type": "string" },
        "logoUrl": { "type": "string" },
        "brandColors": {
          "type": "object",
          "properties": {
            "primary": { "type": "string" },
            "secondary": { "type": "string" }
          }
        },
        "defaultTemplateId": { "type": "string" },
        "paymentConfig": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["custom", "platform"] },
            "paystackPublicKey": { "type": "string" },
            "paystackSecretKey": { "type": "string" }
          }
        }
      },
      "required": ["ownerId"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Invoice document",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "sent", "paid"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile with onboarding state"
    },
    "/businesses/{businessId}": {
      "schema": "Business",
      "description": "Business settings owned by a user"
    },
    "/businesses/{businessId}/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Invoices belonging to a business"
    }
  }
}
